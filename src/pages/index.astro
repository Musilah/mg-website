---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroAsymmetric from "../components/HeroAsymmetric.astro";
import ProductsPreview from "../components/ProductsPreview.astro";
import ProjectsPreview from "../components/ProjectsPreview.astro";
import PartnersCarousel from "../components/PartnersCarousel.astro";
import HomeClosing from "../components/HomeClosing.astro";

const SITE = "https://www.absmach.eu";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE}/#organization`,
    name: "Abstract Machines",
    url: SITE,
    logo: {
      "@type": "ImageObject",
      url: `${SITE}/img/logos/abstract-machines_logo_landscape-black.png`,
    },
    sameAs: [
      "https://github.com/absmach",
      "https://www.linkedin.com/company/abstract-machines",
    ],
    address: {
      "@type": "PostalAddress",
      addressLocality: "Paris",
      addressCountry: "FR",
    },
    foundingDate: "2017",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE}/#website`,
    url: SITE,
    name: "Abstract Machines",
    publisher: { "@id": `${SITE}/#organization` },
  },
];
---

<BaseLayout
  title="Abstract Machines | Open-Source Connectivity Infrastructure"
  description="Abstract Machines builds open-source software and RISC-V hardware for secure, event-driven connectivity across IoT, messaging, orchestration, and distributed systems."
  ogImage="/img/logos/social-preview.png"
  ogImageAlt="Abstract Machines — Open-Source Connectivity Infrastructure"
  jsonLd={jsonLd}
>
  <Header />
  <main>
    <HeroAsymmetric />

    <!-- Partners section -->
    <section class="partners-section">
      <div class="container-wide">
        <div class="partners-header">
          <p class="section-label">Partners &amp; Collaborators</p>
          <h2 class="section-title mt-1">Trusted across Europe</h2>
          <p class="section-subtitle mt-1">
            Research collaborations, EU project memberships, and industry deployments.
          </p>
        </div>
      </div>
      <div class="container-wide">
        <PartnersCarousel />
      </div>
    </section>

    <ProjectsPreview />
    <ProductsPreview />

    <HomeClosing />
  </main>
  <Footer />
</BaseLayout>

<style>
  .partners-section {
    padding-top: clamp(2.5rem, 4vw, 4rem);
    padding-bottom: clamp(1rem, 2vw, 2rem);
  }

  .partners-header {
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .partners-header .section-subtitle {
    margin-inline: auto;
  }
</style>
