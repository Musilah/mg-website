---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroBig from "../../components/HeroBig.astro";
import Section from "../../components/Section.astro";
import FinalCTA from "../../components/FinalCTA.astro";

type Icon = {
  paths: string[];
};

type SolutionCard = {
  title: string;
  description: string;
  points: string[];
  icon: Icon;
};

type SuccessStory = {
  company: string;
  title: string;
  description: string;
  points: string[];
  icon: Icon;
};

const icons = {
  industrial: {
    paths: [
      "M3 21h18",
      "M5 21V9l6 3V9l8 4v8",
      "M9 21v-6",
      "M13 21v-4",
      "M17 21v-5",
    ],
  },
  city: {
    paths: [
      "M3 21h18",
      "M5 21V9l4-2v14",
      "M9 21V5l6 2v14",
      "M15 21v-9l4 2v7",
    ],
  },
  edgeAi: {
    paths: [
      "M9 3v2",
      "M15 3v2",
      "M9 19v2",
      "M15 19v2",
      "M3 9h2",
      "M3 15h2",
      "M19 9h2",
      "M19 15h2",
      "M7 7h10v10H7z",
      "M10 10h4",
      "M12 8v8",
    ],
  },
  health: {
    paths: [
      "M12 21s-7-4.6-9.2-9.1C1.4 9.2 2.6 6.5 5.1 5.4c1.7-.7 3.7-.3 5 1 1.3-1.3 3.3-1.7 5-1 2.5 1.1 3.7 3.8 2.3 6.5C19 16.4 12 21 12 21z",
      "M8.5 12h2l1-2 1.2 4 1-2H16",
    ],
  },
  fleet: {
    paths: [
      "M3 16V7h11v9",
      "M14 10h4l3 3v3h-7",
      "M7 16a2 2 0 1 0 0 4 2 2 0 0 0 0-4",
      "M17 16a2 2 0 1 0 0 4 2 2 0 0 0 0-4",
    ],
  },
  energy: {
    paths: [
      "M13 2L3 14h7l-1 8 10-12h-7l1-8z",
    ],
  },
  proven: {
    paths: [
      "M12 3l7 4v6c0 5-3 9-7 10-4-1-7-5-7-10V7l7-4z",
      "M9 12l2 2 4-5",
    ],
  },
} satisfies Record<string, Icon>;

const solutionCards: SolutionCard[] = [
  {
    title: "Industrial IoT",
    description: "Manage industrial equipment with secure, real-time data flows.",
    points: [
      "Factory Automation",
      "Predictive Maintenance",
      "Supply Chain Tracking",
      "Energy Management",
    ],
    icon: icons.industrial,
  },
  {
    title: "Smart Cities",
    description: "Build intelligent urban infrastructure with distributed sensor networks.",
    points: [
      "Smart Lighting",
      "Traffic Management",
      "Environmental Monitoring",
      "Waste Management",
    ],
    icon: icons.city,
  },
  {
    title: "Edge AI & Analytics",
    description: "Deploy AI workloads at the edge with WebAssembly orchestration.",
    points: [
      "Real-time Analytics",
      "Computer Vision",
      "Anomaly Detection",
      "Local Processing",
    ],
    icon: icons.edgeAi,
  },
  {
    title: "Connected Healthcare",
    description: "Secure patient monitoring and medical device integration.",
    points: ["Remote Monitoring", "Medical IoT", "Data Privacy", "Real-time Alerts"],
    icon: icons.health,
  },
  {
    title: "Fleet Management",
    description: "Track and optimize vehicle fleets with real-time telemetry.",
    points: [
      "GPS Tracking",
      "Fuel Monitoring",
      "Route Optimization",
      "Vehicle Diagnostics",
    ],
    icon: icons.fleet,
  },
  {
    title: "Energy & Utilities",
    description: "Monitor and control distributed energy resources.",
    points: ["Smart Metering", "Grid Management", "Solar Monitoring", "Load Balancing"],
    icon: icons.energy,
  },
];

const successStories: SuccessStory[] = [
  {
    company: "Nokia",
    title: "Data Marketplace Integration",
    description:
      "Magistrala powers Nokia's Data Marketplace, enabling secure IoT data exchange and monetization through real-time MQTT connectors.",
    points: ["Seamless data sharing", "Real-time processing", "Secure monetization"],
    icon: icons.proven,
  },
  {
    company: "Intel",
    title: "Edge Metering Solution",
    description:
      "Real-time metering on the edge with Magistrala integration into EdgeX Foundry for advanced monitoring solutions.",
    points: ["Edge processing", "Real-time metrics", "Linux Foundation integration"],
    icon: icons.proven,
  },
  {
    company: "Ericsson",
    title: "IoT Slice Orchestration",
    description:
      "Enabling orchestration of IoT slices through edge and cloud microservice platforms for next-gen network architecture.",
    points: ["Network slicing", "Microservice orchestration", "Cloud-edge continuum"],
    icon: icons.proven,
  },
];
---

<BaseLayout
  title="Solutions | Abstract Machines"
  description="Transform your operations with proven IoT and edge computing implementations."
>
  <Header />
  <main>
    <HeroBig
      title="Solutions for Every Industry"
      subtitle="Transform your operations with proven IoT and edge computing implementations"
      backgroundClass="hero-grid"
    />

    <section class="py-16">
      <div class="container-wide">
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            solutionCards.map((card) => (
              <article class="card-base">
                <div class="flex items-start gap-4">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-subtle bg-surface-2 text-accent">
                    <svg
                      class="h-6 w-6"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      {card.icon.paths.map((d) => (
                        <path d={d}></path>
                      ))}
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <h3 class="text-xl font-semibold">{card.title}</h3>
                    <p class="mt-2 text-muted">{card.description}</p>
                  </div>
                </div>

                <ul class="mt-5 space-y-2 text-sm text-muted">
                  {card.points.map((point) => (
                    <li class="flex items-start gap-2">
                      <svg
                        class="mt-0.5 h-4 w-4 flex-none text-accent"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M20 6L9 17l-5-5"></path>
                      </svg>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <Section
      title="Proven Success"
      subtitle="Deployed at scale with industry leaders"
      center
    >
      <div class="grid gap-6 md:grid-cols-3">
        {
          successStories.map((story) => (
            <article class="card-base">
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-subtle bg-surface-2 text-accent">
                  <svg
                    class="h-6 w-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {story.icon.paths.map((d) => (
                      <path d={d}></path>
                    ))}
                  </svg>
                </div>
                <div class="min-w-0">
                  <p class="section-label">{story.company}</p>
                  <h3 class="mt-3 text-xl font-semibold">{story.title}</h3>
                </div>
              </div>
              <p class="mt-4 text-muted">{story.description}</p>
              <ul class="mt-5 space-y-2 text-sm text-muted">
                {story.points.map((point) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-[color:var(--muted)]"></span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </Section>

    <FinalCTA
      title="Let's Build Your Solution"
      subtitle="Our team will help design and implement the perfect infrastructure for your needs"
      primary={{ label: "Start a project", href: "/contact/", external: false }}
      secondary={{ label: "View services", href: "/services/", external: false }}
    />
  </main>
  <Footer />
</BaseLayout>

