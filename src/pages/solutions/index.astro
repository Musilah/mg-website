---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroBig from "../../components/HeroBig.astro";
import Section from "../../components/Section.astro";
import FinalCTA from "../../components/FinalCTA.astro";

type SolutionCard = {
  title: string;
  description: string;
  points: string[];
  icon: string[];
};

type Deployment = {
  company: string;
  title: string;
  description: string;
  points: string[];
};

const solutionCards: SolutionCard[] = [
  {
    title: "Industrial IoT",
    description: "Secure, real-time data flows for factory automation and industrial equipment.",
    points: ["Factory Automation", "Predictive Maintenance", "Supply Chain Tracking", "Energy Management"],
    icon: ["M3 21h18", "M5 21V9l6 3V9l8 4v8", "M9 21v-6", "M13 21v-4", "M17 21v-5"],
  },
  {
    title: "Smart Cities",
    description: "Distributed sensor networks for intelligent urban infrastructure.",
    points: ["Smart Lighting", "Traffic Management", "Environmental Monitoring", "Waste Management"],
    icon: ["M3 21h18", "M5 21V9l4-2v14", "M9 21V5l6 2v14", "M15 21v-9l4 2v7"],
  },
  {
    title: "Edge AI & Analytics",
    description: "WebAssembly-orchestrated AI workloads at the network edge.",
    points: ["Real-time Analytics", "Computer Vision", "Anomaly Detection", "Local Processing"],
    icon: ["M9 3v2", "M15 3v2", "M9 19v2", "M15 19v2", "M3 9h2", "M3 15h2", "M19 9h2", "M19 15h2", "M7 7h10v10H7z", "M10 10h4", "M12 8v8"],
  },
  {
    title: "Connected Healthcare",
    description: "Secure patient monitoring and compliant medical device integration.",
    points: ["Remote Monitoring", "Medical IoT", "Data Privacy", "Real-time Alerts"],
    icon: ["M12 21s-7-4.6-9.2-9.1C1.4 9.2 2.6 6.5 5.1 5.4c1.7-.7 3.7-.3 5 1 1.3-1.3 3.3-1.7 5-1 2.5 1.1 3.7 3.8 2.3 6.5C19 16.4 12 21 12 21z", "M8.5 12h2l1-2 1.2 4 1-2H16"],
  },
  {
    title: "Fleet Management",
    description: "Real-time vehicle telemetry and route optimisation at scale.",
    points: ["GPS Tracking", "Fuel Monitoring", "Route Optimisation", "Vehicle Diagnostics"],
    icon: ["M3 16V7h11v9", "M14 10h4l3 3v3h-7", "M7 16a2 2 0 1 0 0 4 2 2 0 0 0 0-4", "M17 16a2 2 0 1 0 0 4 2 2 0 0 0 0-4"],
  },
  {
    title: "Energy & Utilities",
    description: "Monitoring and control for distributed energy resources and smart grids.",
    points: ["Smart Metering", "Grid Management", "Solar Monitoring", "Load Balancing"],
    icon: ["M13 2L3 14h7l-1 8 10-12h-7l1-8z"],
  },
];

const deployments: Deployment[] = [
  {
    company: "Nokia",
    title: "Data Marketplace",
    description:
      "Magistrala powers Nokia's Data Marketplace, enabling secure IoT data exchange and monetisation through real-time MQTT connectors.",
    points: ["Seamless data sharing", "Real-time processing", "Secure monetisation"],
  },
  {
    company: "Intel",
    title: "Edge Metering",
    description:
      "Real-time metering on the edge with Magistrala integrated into EdgeX Foundry for advanced monitoring solutions.",
    points: ["Edge processing", "Real-time metrics", "Linux Foundation integration"],
  },
  {
    company: "Ericsson",
    title: "IoT Slice Orchestration",
    description:
      "Orchestration of IoT slices through edge and cloud microservice platforms for next-generation network architecture.",
    points: ["Network slicing", "Microservice orchestration", "Cloud-edge continuum"],
  },
];
---

<BaseLayout
  title="Solutions | Abstract Machines"
  description="IoT and edge computing solutions across industrial, smart city, healthcare, fleet, and energy use cases — built on the Abstract Machines open-source stack."
>
  <Header />
  <main>
    <HeroBig
      kicker="Solutions"
      title="Infrastructure for the real world."
      subtitle="The Abstract Machines stack — Magistrala, Propeller, FluxMQ, and RISC-V hardware — deployed across industrial, research, and enterprise environments."
      primary={{ label: "Start a project", href: "/contact/", external: false }}
      secondary={{ label: "View services", href: "/services/", external: false }}
    />

    <Section title="Industry use cases" subtitle="Common deployment patterns across verticals.">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {solutionCards.map((card) => (
          <article class="card-base">
            <div class="flex items-start gap-3 mb-3">
              <svg
                class="h-5 w-5 text-accent flex-shrink-0 mt-0.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {card.icon.map((d) => <path d={d} />)}
              </svg>
              <div>
                <h3 class="text-base font-semibold">{card.title}</h3>
                <p class="mt-1 text-sm text-muted">{card.description}</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-1.5 mt-3">
              {card.points.map((point) => (
                <span class="sol-tag">{point}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </Section>

    <Section
      title="Deployed in production"
      subtitle="Real deployments, real companies. No case study padding."
      center
    >
      <div class="grid gap-5 md:grid-cols-3">
        {deployments.map((d) => (
          <article class="card-base flex flex-col">
            <div class="deployment-company-row">
              <span class="section-label">{d.company}</span>
            </div>
            <h3 class="mt-3 text-base font-semibold">{d.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{d.description}</p>
            <ul class="mt-4 space-y-1.5 pt-4 border-t border-subtle">
              {d.points.map((point) => (
                <li class="flex items-center gap-2 text-sm text-muted">
                  <span class="h-1 w-3 flex-none rounded-full bg-accent opacity-60"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Section>

    <FinalCTA
      title="Let's scope your deployment."
      subtitle={null}
      primary={{ label: "Get in touch", href: "/contact/", external: false }}
      secondary={{ label: "View services", href: "/services/", external: false }}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  .sol-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.5rem;
    font-size: 0.7rem;
    font-weight: 500;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    background: var(--surface);
    font-family: 'JetBrains Mono', monospace;
  }

  .deployment-company-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>
