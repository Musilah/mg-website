---
export const prerender = true;

import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import AudioReader from "../../components/AudioReader.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blogs", ({ data }) => !data.draft);

    return posts.map((post) => ({
        params: { slug: post.data.slug ?? post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = `${post.data.title} | Blog`;
const description = post.data.description;
const currentSlug = post.data.slug ?? post.slug;
const publishedAt =
    post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
const coverImage = post.data.coverImage ?? post.data.heroImage ?? null;
const coverVideo = post.data.coverVideo ?? null;
const getYouTubeEmbedSrc = (rawUrl) => {
    try {
        const url = new URL(rawUrl);
        const hostname = url.hostname.replace(/^www\./, "");
        let videoId = "";

        if (hostname === "youtu.be") {
            videoId = url.pathname.slice(1);
        } else if (
            hostname === "youtube.com" ||
            hostname === "m.youtube.com" ||
            hostname === "youtube-nocookie.com"
        ) {
            if (url.pathname === "/watch") {
                videoId = url.searchParams.get("v") ?? "";
            } else if (url.pathname.startsWith("/embed/")) {
                videoId = url.pathname.split("/")[2] ?? "";
            } else if (url.pathname.startsWith("/shorts/")) {
                videoId = url.pathname.split("/")[2] ?? "";
            }
        }

        if (!videoId) return null;

        const embedBase =
            hostname === "youtube-nocookie.com"
                ? "https://www.youtube-nocookie.com"
                : "https://www.youtube.com";
        const embedUrl = new URL(`${embedBase}/embed/${videoId}`);
        embedUrl.searchParams.set("autoplay", "1");
        embedUrl.searchParams.set("mute", "1");
        embedUrl.searchParams.set("playsinline", "1");
        embedUrl.searchParams.set("rel", "0");
        return embedUrl.toString();
    } catch {
        return null;
    }
};
const coverVideoIframeSrc = coverVideo ? getYouTubeEmbedSrc(coverVideo) : null;
const canonical =
    post.data.canonical ?? `/blog/${post.data.slug ?? post.slug}/`;
const normalizedCategory = (post.data.category ?? "").toLowerCase().trim();
const postBadgeChips = (() => {
    const chips = [];
    if (normalizedCategory === "announcement") chips.push("announcement");
    if (post.data.featured) chips.push("featured");
    return chips;
})();
const getCardBadgeChips = (category = "", featured = false) => {
    const chips = [];
    const normalized = category.toLowerCase().trim();
    if (normalized === "announcement") chips.push("announcement");
    if (!normalized) chips.push("blog");
    if (featured) chips.push("featured");
    return chips;
};
const badgeClassFor = (tag) =>
    tag === "featured"
        ? "inline-flex rounded-md border border-subtle bg-surface px-3 py-1 text-sm font-semibold capitalize text-accent"
        : tag === "blog"
          ? "inline-flex rounded-md border border-subtle bg-surface-2 px-3 py-1 text-sm font-semibold capitalize text-muted"
        : "inline-flex rounded-md border border-accent/35 bg-accent/15 px-3 py-1 text-sm font-semibold capitalize text-primary";
const stripMarkdown = (content = "") =>
    String(content)
        .replace(/```[\s\S]*?```/g, " ")
        .replace(/`[^`]*`/g, " ")
        .replace(/!\[[^\]]*]\([^)]+\)/g, " ")
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
        .replace(/<[^>]*>/g, " ")
        .replace(/[#>*_~\-]/g, " ")
        .replace(/\s+/g, " ")
        .trim();
const estimateReadingMinutes = (content = "") => {
    const plain = stripMarkdown(content);
    const words = plain ? plain.split(/\s+/).length : 0;
    return Math.max(1, Math.ceil(words / 200));
};
const readingMinutes = estimateReadingMinutes(post.body ?? "");
const SITE = "https://www.absmach.eu";

const shareUrl = /^https?:\/\//.test(canonical)
    ? canonical
    : Astro.site
      ? new URL(canonical, Astro.site).toString()
      : canonical;

const articleUrl = /^https?:\/\//.test(canonical)
    ? canonical
    : `${SITE}${canonical.startsWith("/") ? "" : "/"}${canonical}`;

const jsonLd = [
    {
        "@context": "https://schema.org",
        "@type": "Article",
        "@id": `${articleUrl}#article`,
        headline: post.data.title,
        description: post.data.description,
        url: articleUrl,
        datePublished: publishedAt.toISOString(),
        author: {
            "@type": "Person",
            name: post.data.author.name,
        },
        publisher: {
            "@type": "Organization",
            "@id": `${SITE}/#organization`,
            name: "Abstract Machines",
            logo: {
                "@type": "ImageObject",
                url: `${SITE}/img/logos/abstract-machines_logo_landscape-black.png`,
            },
        },
        ...(coverImage
            ? {
                  image: {
                      "@type": "ImageObject",
                      url: /^https?:\/\//.test(coverImage)
                          ? coverImage
                          : `${SITE}${coverImage}`,
                  },
              }
            : {}),
        mainEntityOfPage: {
            "@type": "WebPage",
            "@id": articleUrl,
        },
    },
    {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
            {
                "@type": "ListItem",
                position: 1,
                name: "Home",
                item: SITE,
            },
            {
                "@type": "ListItem",
                position: 2,
                name: "Blog",
                item: `${SITE}/blog/`,
            },
            {
                "@type": "ListItem",
                position: 3,
                name: post.data.title,
                item: articleUrl,
            },
        ],
    },
];
const twitterShareHref = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(shareUrl)}`;
const linkedInShareHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
const allPosts = await getCollection("blogs", ({ data }) => !data.draft);
const nextReadPosts = allPosts
    .filter((entry) => (entry.data.slug ?? entry.slug) !== currentSlug)
    .sort(
        (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    )
    .slice(0, 3)
    .map((entry) => {
        const entryDate =
            entry.data.date instanceof Date
                ? entry.data.date
                : new Date(entry.data.date);
        return {
            title: entry.data.title,
            description: entry.data.description,
            href: `/blog/${entry.data.slug ?? entry.slug}/`,
            coverImage: entry.data.coverImage ?? entry.data.heroImage ?? null,
            authorName: entry.data.author?.name ?? "Abstract Machines",
            authorPicture: entry.data.author?.picture ?? null,
            tags: (entry.data.tags ?? []).slice(0, 8),
            dateLabel: entryDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "2-digit",
            }),
            readingMinutes: estimateReadingMinutes(entry.body ?? ""),
            badgeChips: getCardBadgeChips(
                entry.data.category ?? "",
                entry.data.featured ?? false,
            ),
        };
    });
---

<BaseLayout
    title={title}
    description={description}
    ogType="article"
    ogImage={coverImage ?? "/img/logos/social-preview.png"}
    ogImageAlt={post.data.title}
    canonical={canonical}
    jsonLd={jsonLd}
>
    <Header />
    <main>
        <section class="hero-grid pt-20 pb-8 md:py-10">
            <div class="container-wide">
                <div class="mx-auto max-w-4xl">
                    <a class="nav-link inline-flex items-center gap-2" href="/blog/">
                        ← Back to Blog
                    </a>

                    {
                        postBadgeChips.length > 0 && (
                            <div class="mt-4 flex flex-wrap gap-2">
                                {postBadgeChips.map((chip) => (
                                    <span class={badgeClassFor(chip)}>
                                        {chip}
                                    </span>
                                ))}
                            </div>
                        )
                    }

                    <h1 class="mt-4 text-4xl font-semibold tracking-tight md:text-5xl lg:text-6xl">
                        {post.data.title}
                    </h1>

                    <div class="mt-6 flex items-center gap-4">
                        {
                            post.data.author.picture ? (
                                <Image
                                    src={post.data.author.picture!}
                                    alt={post.data.author.name}
                                    width={56}
                                    height={56}
                                    class="h-14 w-14 rounded-full border border-subtle bg-surface-2 object-cover"
                                    loading="eager"
                                    decoding="async"
                                />
                            ) : (
                                <div class="flex h-14 w-14 items-center justify-center rounded-full border border-subtle bg-surface-2 font-semibold text-primary">
                                    {post.data.author.name.slice(0, 1)}
                                </div>
                            )
                        }

                        <div class="min-w-0">
                            <p class="text-xl font-semibold text-primary">
                                {post.data.author.name}
                            </p>
                            <p class="mt-1 text-base text-muted">
                                {
                                    publishedAt.toLocaleDateString("en-US", {
                                        year: "numeric",
                                        month: "long",
                                        day: "2-digit",
                                    })
                                }{" "}
                                • {readingMinutes} min read
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="pt-4 pb-14 md:pb-16">
            <div class="container-wide">
                <div class="mx-auto max-w-4xl">
                    {
                        (coverVideo || coverImage) && (
                            <div class="mb-8 aspect-video overflow-hidden rounded-3xl border border-subtle shadow-[var(--shadow-soft)]">
                                {coverVideo ? (
                                    coverVideoIframeSrc ? (
                                        <iframe
                                            src={coverVideoIframeSrc}
                                            class="h-full w-full border-0"
                                            title={`${post.data.title} cover video`}
                                            allow="autoplay; encrypted-media; picture-in-picture; web-share"
                                            allowfullscreen
                                        />
                                    ) : (
                                        <video
                                            src={coverVideo}
                                            class="h-full w-full object-cover"
                                            controls
                                            autoplay
                                            muted
                                            playsinline
                                            preload="metadata"
                                            poster={coverImage ?? undefined}
                                        >
                                            Your browser does not support the
                                            video tag.
                                        </video>
                                    )
                                ) : (
                                    <Image
                                        src={coverImage!}
                                        alt=""
                                        width={1280}
                                        height={720}
                                        class="cover-image h-full w-full"
                                        loading="eager"
                                        decoding="async"
                                    />
                                )}
                            </div>
                        )
                    }
                    <article class="mx-auto max-w-3xl">
                    <AudioReader target="#post" />
                    <div
                        id="post"
                        class="prose prose-theme max-w-none prose-a:text-accent prose-img:rounded-2xl prose-img:border prose-img:border-[color:var(--border)]"
                    >
                        <Content />
                    </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="pb-20">
            <div class="container-wide">
                <div class="mx-auto max-w-4xl border-t border-subtle pt-10">
                    <a
                        class="inline-flex items-center gap-2 rounded-lg border border-subtle bg-surface px-4 py-2 text-base font-medium text-primary transition hover:-translate-y-0.5"
                        href="/blog/"
                    >
                        ← Back to Blog
                    </a>

                    <div class="mt-10">
                        <h2 class="text-3xl font-semibold text-primary">Tags</h2>
                        <div class="mt-4 flex flex-wrap gap-2.5">
                            {(post.data.tags?.length ? post.data.tags : ["General"]).map((tag) => (
                                <a
                                    class="rounded-md bg-surface px-3 py-1.5 text-lg font-semibold text-primary transition hover:bg-surface-2"
                                    href={`/blog/?tags=${encodeURIComponent(tag)}`}
                                >
                                    {tag}
                                </a>
                            ))}
                        </div>
                    </div>

                    <div class="mt-10">
                        <h2 class="text-3xl font-semibold text-primary">Share this article</h2>
                        <div class="mt-4 flex flex-wrap items-center gap-3">
                            <a
                                class="inline-flex items-center gap-2 rounded-lg border border-subtle px-4 py-2 text-base font-medium text-primary transition hover:-translate-y-0.5"
                                href={twitterShareHref}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="Share this article on Twitter"
                            >
                                <svg
                                    class="h-4 w-4"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <path d="M18.244 2H21l-6.54 7.476L22.154 22h-6.02l-4.715-6.166L6.02 22H3.262l6.995-7.995L1.846 2h6.173l4.262 5.633L18.244 2Zm-2.11 18h1.666L7.11 3.894H5.322L16.134 20Z"></path>
                                </svg>
                                Twitter
                            </a>

                            <a
                                class="inline-flex items-center gap-2 rounded-lg border border-subtle px-4 py-2 text-base font-medium text-primary transition hover:-translate-y-0.5"
                                href={linkedInShareHref}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="Share this article on LinkedIn"
                            >
                                <svg
                                    class="h-4 w-4"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    aria-hidden="true"
                                >
                                    <path d="M19 3A2 2 0 0 1 21 5v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14Zm-.5 15.5v-5.3c0-2.84-1.52-4.16-3.55-4.16-1.64 0-2.37.9-2.77 1.54v-1.32H9.36c.04.87 0 9.24 0 9.24h2.82v-5.16c0-.27.02-.55.1-.75.21-.55.69-1.12 1.5-1.12 1.06 0 1.49.82 1.49 2.02v5.01h2.73ZM6.39 8.1c.98 0 1.58-.65 1.58-1.46-.02-.83-.6-1.46-1.56-1.46s-1.58.63-1.58 1.46c0 .81.6 1.46 1.54 1.46h.02Zm-1.43 10.4h2.82V9.26H4.96V18.5Z"></path>
                                </svg>
                                LinkedIn
                            </a>
                        </div>
                    </div>

                    <div class="mt-20 mx-auto max-w-3xl text-center">
                        <h2 class="section-title">Subscribe to Our Newsletter</h2>
                        <p class="section-subtitle mt-4">
                            Stay updated with the latest news, updates and announcements.
                        </p>
                        <form
                            action="https://absmach.us11.list-manage.com/subscribe/post?u=70b43c7181d005024187bfb31&id=0a319b6b63&f_id=002611e1f0"
                            method="post"
                            target="_blank"
                            class="mx-auto mt-8 max-w-2xl"
                        >
                            <div class="flex flex-col overflow-hidden rounded-xl border border-subtle bg-panel sm:flex-row">
                                <label class="w-full sm:flex-1">
                                    <span class="sr-only">Email</span>
                                    <input
                                        class="input-base w-full border-0 bg-transparent px-4 py-3.5 text-base outline-none"
                                        id="mce-EMAIL"
                                        name="EMAIL"
                                        placeholder="Enter your email"
                                        required
                                        type="email"
                                    />
                                </label>
                                <button class="button-primary !rounded-none !px-7 !py-3.5" type="submit">
                                    Subscribe
                                </button>
                            </div>
                            <input name="tags" type="hidden" value="8115259" />
                            <div aria-hidden="true" class="absolute left-[-5000px]">
                                <input
                                    name="b_70b43c7181d005024187bfb31_0a319b6b63"
                                    tabindex="-1"
                                    type="text"
                                    value=""
                                />
                            </div>
                        </form>
                        <p class="mt-4 text-sm text-muted">
                            By subscribing, you agree to our
                            <a class="text-accent" href="/privacy/">Privacy Policy</a> and
                            <a class="text-accent" href="/terms/">Terms of Service</a>.
                        </p>
                        <p class="mt-1 text-sm text-muted">
                            You can unsubscribe at any time.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        {
            nextReadPosts.length > 0 && (
                <section class="pb-24">
                    <div class="container-wide">
                        <div class="mx-auto max-w-6xl">
                            <h2 class="text-3xl font-semibold tracking-tight text-primary md:text-4xl">
                                Next Read
                            </h2>

                            <div class="mt-7 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
                                {nextReadPosts.map((entry, index) => (
                                    <a
                                        href={entry.href}
                                        class="card-base flex h-full flex-col overflow-hidden !p-0 hover:shadow-[var(--shadow-strong)]"
                                    >
                                        {
                                            entry.coverImage && (
                                                <div class="aspect-[16/9] overflow-hidden border-b border-subtle">
                                                    <Image
                                                        src={entry.coverImage}
                                                        alt=""
                                                        width={1280}
                                                        height={720}
                                                        class="cover-image h-full w-full"
                                                        loading={index === 0
                                                            ? "eager"
                                                            : "lazy"}
                                                        decoding="async"
                                                    />
                                                </div>
                                            )
                                        }

                                        <div class="flex flex-1 flex-col p-5">
                                            {entry.badgeChips.length > 0 && (
                                                <div class="mb-3 flex flex-wrap gap-2">
                                                    {entry.badgeChips.map((chip) => (
                                                        <span class={badgeClassFor(chip)}>
                                                            {chip}
                                                        </span>
                                                    ))}
                                                </div>
                                            )}

                                            <h3 class="text-3xl font-semibold leading-tight text-primary">
                                                {entry.title}
                                            </h3>

                                            <p class="mt-3 text-muted">
                                                {entry.description}
                                            </p>

                                            <div class="mt-5 flex items-center gap-3">
                                                {
                                                    entry.authorPicture ? (
                                                        <Image
                                                            src={entry.authorPicture}
                                                            alt={entry.authorName}
                                                            width={36}
                                                            height={36}
                                                            class="h-9 w-9 rounded-full border border-subtle bg-surface-2 object-cover"
                                                            loading="lazy"
                                                            decoding="async"
                                                        />
                                                    ) : (
                                                        <div class="flex h-9 w-9 items-center justify-center rounded-full border border-subtle bg-surface-2 text-sm font-semibold text-primary">
                                                            {entry.authorName.slice(0, 1)}
                                                        </div>
                                                    )
                                                }

                                                <div class="min-w-0">
                                                    <p class="truncate text-lg font-semibold text-primary">
                                                        {entry.authorName}
                                                    </p>
                                                    <p class="text-base text-muted">
                                                        {entry.dateLabel} • {entry.readingMinutes} min
                                                        read
                                                    </p>
                                                </div>
                                            </div>

                                            {entry.tags.length > 0 && (
                                                <div class="mt-5 flex flex-wrap gap-2">
                                                    {entry.tags.map((tag) => (
                                                        <span class="rounded-md bg-surface-2 px-2.5 py-1 text-xs font-semibold text-primary">
                                                            {tag}
                                                        </span>
                                                    ))}
                                                </div>
                                            )}
                                        </div>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                </section>
            )
        }
    </main>
    <Footer />
</BaseLayout>

<style>
    .cover-image {
        object-fit: cover;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const coverImages = document.querySelectorAll('.cover-image');
        
        coverImages.forEach((img) => {
            if (img instanceof HTMLImageElement) {
                const checkOrientation = () => {
                    if (img.naturalHeight > img.naturalWidth) {
                        img.style.objectFit = 'contain';
                        const parent = img.parentElement;
                        if (parent) {
                            parent.style.backgroundColor = 'transparent';
                        }
                    } else {
                        img.style.objectFit = 'cover';
                    }
                };
                
                if (img.complete) {
                    checkOrientation();
                } else {
                    img.addEventListener('load', checkOrientation);
                }
            }
        });
    });
</script>
