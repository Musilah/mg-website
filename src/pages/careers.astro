---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Section from "../components/Section.astro";

const benefits = [
  {
    title: "Remote-First",
    description: "Work from anywhere in Europe. Flexible hours, async-friendly culture.",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Open Source",
    description: "Your work ships to thousands of engineers, openly and permanently.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  },
  {
    title: "EU Research",
    description: "Work on Horizon Europe programmes at the frontier of 6G and edge computing.",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    title: "Technical Depth",
    description: "Distributed systems, WebAssembly, RISC-V, confidential computing — real hard problems.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    title: "Real Impact",
    description: "Production deployments at Nokia, Intel, and Ericsson. Not side projects.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
  {
    title: "Fair Compensation",
    description: "Market-rate salary, equity where applicable, conference budget.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];

const steps = [
  { n: "01", title: "Apply", body: "Send a short intro and your GitHub or relevant work to info@absmach.eu." },
  { n: "02", title: "Screen", body: "A quick call with someone from the team to understand mutual fit." },
  { n: "03", title: "Technical", body: "A focused technical conversation — no whiteboard puzzles, just real problems." },
  { n: "04", title: "Offer", body: "Fast decision. If it's a fit, we move quickly." },
];
---

<BaseLayout
  title="Careers | Abstract Machines"
  description="Join Abstract Machines and build open-source infrastructure for secure IoT and edge computing."
>
  <Header />
  <main>

    <!-- Page header -->
    <section class="careers-hero">
      <div class="container-wide">
        <p class="section-label">Careers</p>
        <h1 class="careers-hero-title">Work on infrastructure<br>that matters.</h1>
        <p class="careers-hero-sub">
          Abstract Machines is a small, technical team in Paris building open-source
          software and hardware for distributed systems. We work on hard problems
          in IoT, edge computing, and 6G — and we ship to production.
        </p>
      </div>
    </section>

    <!-- Why join -->
    <Section title="Why Abstract Machines?" subtitle="What it's like to work here.">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map((b) => (
          <article class="card-base flex flex-col gap-3">
            <svg
              class="h-5 w-5 text-accent flex-shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={b.icon} />
            </svg>
            <div>
              <h3 class="font-semibold text-base">{b.title}</h3>
              <p class="mt-1 text-sm text-muted leading-relaxed">{b.description}</p>
            </div>
          </article>
        ))}
      </div>
    </Section>

    <!-- Open positions -->
    <Section title="Open positions" subtitle="Current hiring status.">
      <div class="positions-empty">
        <p class="positions-label">Not hiring right now</p>
        <p class="positions-body">
          We don't have open roles at the moment. If you're interested in
          future opportunities, feel free to introduce yourself via
          <a href="/contact/">email</a> — we keep strong applicants in mind.
        </p>
      </div>
    </Section>

    <!-- Process -->
    <Section title="How we hire" subtitle="Simple, fast, no surprises.">
      <ol class="process-steps">
        {steps.map((s) => (
          <li class="process-step">
            <span class="process-n" aria-hidden="true">{s.n}</span>
            <div>
              <h3 class="process-title">{s.title}</h3>
              <p class="process-body">{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </Section>

    <FinalCTA
      title="Interested in future roles?"
      subtitle={null}
      primary={{ label: "Get in touch", href: "/contact/", external: false }}
      secondary={{ label: "See our work on GitHub", href: "https://github.com/absmach", external: true }}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .careers-hero {
    padding-top: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(2rem, 3.5vw, 3rem);
  }

  .careers-hero-title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.08;
    color: var(--text);
    margin-top: 0.65rem;
    max-width: 18ch;
  }

  .careers-hero-sub {
    font-size: clamp(0.95rem, 1.35vw, 1.05rem);
    color: var(--muted);
    line-height: 1.75;
    margin-top: 1rem;
    max-width: 56ch;
  }

  /* ── Open positions ───────────────────────────────────── */
  .positions-empty {
    max-width: 40rem;
    padding: 1.5rem 1.75rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--panel);
  }

  .positions-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    margin-bottom: 0.6rem;
  }

  .positions-body {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .positions-body a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: none;
  }

  .positions-body a:hover {
    color: var(--text);
  }

  /* ── Process steps ────────────────────────────────────── */
  .process-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
    max-width: 48rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--panel);
  }

  .process-step {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .process-step:last-child {
    border-bottom: none;
  }

  .process-n {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    opacity: 0.7;
    padding-top: 0.2rem;
    flex-shrink: 0;
    min-width: 2rem;
  }

  .process-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .process-body {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
    margin-top: 0.25rem;
  }
</style>
