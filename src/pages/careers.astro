---
// pages/careers.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FinalCTA from "../components/FinalCTA.astro";
const benefits = [
  {
    title: "Remote-First",
    description: "Work from anywhere in Europe with flexible hours",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    title: "Open Source",
    description: "Contribute to projects used by thousands",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  },
  {
    title: "Research",
    description: "Work on cutting-edge EU research projects",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    title: "Growth",
    description: "Continuous learning and conference attendance",
    icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
  },
  {
    title: "Impact",
    description: "Build infrastructure used by industry leaders",
    icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
  },
  {
    title: "Competitive",
    description: "Market-rate compensation and equity",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];
---

<BaseLayout title="Careers">
  <Header />
  <!-- Hero -->
  <section class="py-32 px-6 hero-grid">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="text-6xl md:text-7xl font-display font-bold mb-6">
        Build the Future With Us
      </h1>
      <p class="text-2xl text-muted max-w-3xl mx-auto">
        Join a team pushing the boundaries of distributed systems and edge
        computing
      </p>
    </div>
  </section>

  <!-- Why Join -->
  <section class="py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-5xl font-display font-bold mb-4">
          Why Abstract Machines?
        </h2>
        <p class="text-xl text-muted">What makes us different</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          benefits.map((benefit) => (
            <div class="p-8 rounded-2xl border border-subtle bg-panel transition-all hover:border-accent hover:shadow-[var(--shadow-soft)]">
              <div class="w-14 h-14 bg-electric-cyan/10 rounded-xl flex items-center justify-center mb-6">
                <svg
                  class="w-7 h-7 text-electric-cyan"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={benefit.icon}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-display font-bold mb-3">
                {benefit.title}
              </h3>
              <p class="text-muted">{benefit.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Open Positions -->
  <section class="py-32 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-5xl font-display font-bold mb-4">Open Positions</h2>
        <p class="text-xl text-muted">We are not hiring right now</p>
      </div>

      <div class="max-w-3xl mx-auto rounded-2xl border border-subtle bg-panel p-8 text-center">
        <p class="text-muted">
          There are currently no open positions. You can still reach out via
          our
          <a href="/contact/" class="text-primary underline-offset-4 hover:underline"> contact page</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="py-32 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-5xl font-display font-bold mb-4">Our Process</h2>
        <p class="text-xl text-muted">What to expect when you apply</p>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center">
          <div
            class="w-16 h-16 bg-electric-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display font-bold text-electric-cyan"
              >1</span
            >
          </div>
          <h3 class="font-display font-bold mb-2">Apply</h3>
          <p class="text-sm text-muted">Submit your application via email</p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 bg-electric-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display font-bold text-electric-cyan"
              >2</span
            >
          </div>
          <h3 class="font-display font-bold mb-2">Screen</h3>
          <p class="text-sm text-muted">Initial conversation with our team</p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 bg-electric-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display font-bold text-electric-cyan"
              >3</span
            >
          </div>
          <h3 class="font-display font-bold mb-2">Interview</h3>
          <p class="text-sm text-muted">
            Technical and cultural fit assessment
          </p>
        </div>

        <div class="text-center">
          <div
            class="w-16 h-16 bg-electric-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display font-bold text-electric-cyan"
              >4</span
            >
          </div>
          <h3 class="font-display font-bold mb-2">Offer</h3>
          <p class="text-sm text-muted">Welcome to the team!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <FinalCTA
    title="Don't See a Fit?"
    subtitle="We're always interested in hearing from talented people. Send us your resume and let's talk!"
    primary={{ label: "Get in Touch", href: "/contact/", external: false }}
    secondary={null}
  />
  <Footer />
</BaseLayout>
