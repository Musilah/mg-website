---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroBig from "../../components/HeroBig.astro";
import Section from "../../components/Section.astro";
import FinalCTA from "../../components/FinalCTA.astro";

type Project = {
  name: string;
  tagline: string;
  description: string;
  status: string;
  statusTone: "active" | "completed" | "ongoing" | "member";
  year: string;
  funding: string;
  areas: string[];
  logo?: string;
  logoInverted?: boolean;
  link: string;
};

const projects: Project[] = [
  {
    name: "CONFIDENTIAL6G",
    tagline: "Quantum-Resistant Security for 6G Networks",
    description:
      "Developing cryptographic protocols and security mechanisms to ensure confidentiality in next-generation 6G networks. Building quantum-resistant libraries and architectural blueprints for secure telecommunications.",
    status: "Completed",
    statusTone: "completed",
    year: "2023–2025",
    funding: "EU Horizon Europe",
    areas: ["6G Security", "Quantum Cryptography", "Network Architecture", "Privacy"],
    logo: "/img/logos/confidential6G.jpg",
    logoInverted: false,
    link: "/projects/confidential6g/",
  },
  {
    name: "Elastic",
    tagline: "Next-Gen Network Orchestration",
    description:
      "WebAssembly-based network orchestration with Confidential Computing for efficient, secure service delivery across 6G infrastructures. Enabling dynamic workload distribution from cloud to edge.",
    status: "Active",
    statusTone: "active",
    year: "2024–2027",
    funding: "EU Horizon Europe",
    areas: ["WebAssembly", "Edge Computing", "Confidential Computing", "6G"],
    logo: "/img/logos/elastic.png",
    logoInverted: true,
    link: "/projects/elastic/",
  },
  {
    name: "EdgeX Foundry",
    tagline: "Open Source Edge Platform",
    description:
      "Contributing to the Linux Foundation's EdgeX Foundry project, providing edge intelligence and interoperability for IoT deployments. Magistrala integration enables seamless edge-cloud communication.",
    status: "Ongoing",
    statusTone: "ongoing",
    year: "2017–Present",
    funding: "Linux Foundation",
    areas: ["Edge Computing", "IoT", "Open Source", "Interoperability"],
    logo: "/img/logos/lf.png",
    logoInverted: false,
    link: "https://www.edgexfoundry.org",
  },
  {
    name: "6G-IA",
    tagline: "European 6G Industry Association",
    description:
      "Active participation in shaping Europe's 6G vision and standards. Contributing to industrial IoT use cases, security frameworks, and edge computing architectures for next-generation networks.",
    status: "Member",
    statusTone: "member",
    year: "2021–Present",
    funding: "Industry Consortium",
    areas: ["6G Standards", "Industry Collaboration", "Policy", "Innovation"],
    logo: "/img/logos/6g-ia-long.png",
    logoInverted: false,
    link: "https://6g-ia.eu",
  },
];

const researchAreas = [
  {
    title: "Edge Intelligence",
    description: "Distributed AI and machine learning at the network edge.",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    title: "Confidential Computing",
    description: "Secure execution environments for sensitive workloads.",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z",
  },
  {
    title: "Network Slicing",
    description: "Dynamic resource allocation for heterogeneous services.",
    icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4",
  },
  {
    title: "Zero Trust Architecture",
    description: "Security models for distributed systems.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
];

const impactStats = [
  { value: "5+", label: "Open-source products" },
  { value: "5+", label: "EU-funded projects" },
  { value: "15+", label: "Research partners" },
];
---

<BaseLayout
  title="Projects | Abstract Machines"
  description="Explore research projects and collaborations involving Abstract Machines across edge computing, 6G, and secure distributed systems."
>
  <Header />

  <main>
    <HeroBig
      kicker="Research &amp; Projects"
      title="Advancing the edge, one programme at a time."
      subtitle="EU Horizon Europe projects, Linux Foundation collaborations, and industry consortium memberships — driving standards and practice in 6G, edge computing, and secure distributed systems."
      primary={{ label: "Partner with us", href: "/contact/", external: false }}
      secondary={{ label: "Explore projects", href: "#projects", external: false }}
    />

    <Section
      title="Projects &amp; Collaborations"
      subtitle="EU-funded research initiatives and open-source ecosystem participation."
      id="projects"
    >
      <div class="grid gap-5 lg:grid-cols-2">
        {projects.map((project, index) => {
          const isExternal = project.link.startsWith("http");
          return (
            <article class="project-card card-base flex h-full flex-col">
              <div class="flex items-start justify-between gap-4">
                <div class="flex min-w-0 items-start gap-3">
                  <div class="project-logo-wrap">
                    {project.logo ? (
                      <Image
                        src={project.logo}
                        alt={`${project.name} logo`}
                        class={`h-10 w-full object-contain ${project.logoInverted ? "invert dark:invert-0" : ""}`}
                        width={200}
                        height={80}
                        loading={index < 2 ? "eager" : "lazy"}
                        decoding="async"
                      />
                    ) : (
                      <span class="text-base font-semibold text-muted">{project.name.slice(0,3)}</span>
                    )}
                  </div>
                  <div class="min-w-0">
                    <h3 class="text-lg font-semibold leading-tight">{project.name}</h3>
                    <p class="mt-1 text-base text-muted">{project.tagline}</p>
                  </div>
                </div>
                <span class={`project-status project-status--${project.statusTone}`}>
                  {project.status}
                </span>
              </div>

              <p class="mt-4 text-base text-muted leading-relaxed">{project.description}</p>

              <div class="mt-4 flex flex-wrap gap-1.5">
                {project.areas.map((area) => (
                  <span class="project-tag">{area}</span>
                ))}
              </div>

              <dl class="mt-5 grid gap-3 sm:grid-cols-2 border-t border-subtle pt-4">
                <div>
                  <dt class="project-dl-label">Duration</dt>
                  <dd class="project-dl-value">{project.year}</dd>
                </div>
                <div>
                  <dt class="project-dl-label">Funding</dt>
                  <dd class="project-dl-value">{project.funding}</dd>
                </div>
              </dl>

              <div class="mt-auto pt-4">
                <a
                  class="inline-flex text-base font-semibold text-accent hover:opacity-75 transition-opacity"
                  href={project.link}
                  target={isExternal ? "_blank" : undefined}
                  rel={isExternal ? "noopener noreferrer" : undefined}
                >
                  {isExternal ? "Visit website ↗" : "Learn more →"}
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </Section>

    <Section
      title="Research focus areas"
      subtitle="Core competencies driving our innovation."
      center
    >
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {researchAreas.map((area) => (
          <article class="card-base">
            <svg
              class="h-5 w-5 text-accent mb-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={area.icon} />
            </svg>
            <h3 class="text-base font-semibold">{area.title}</h3>
            <p class="mt-2 text-base text-muted leading-relaxed">{area.description}</p>
          </article>
        ))}
      </div>
    </Section>

    <Section title="Impact &amp; recognition" center>
      <div class="grid gap-5 md:grid-cols-3 max-w-2xl mx-auto">
        {impactStats.map((stat) => (
          <article class="card-base text-center">
            <p class="text-4xl font-semibold tracking-tight text-accent">{stat.value}</p>
            <p class="mt-2 text-base text-muted">{stat.label}</p>
          </article>
        ))}
      </div>
    </Section>

    <FinalCTA
      title="Interested in collaborating?"
      subtitle={null}
      primary={{ label: "Get in touch", href: "/contact/", external: false }}
      secondary={null}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Project cards ─────────────────────────────────────── */
  .project-card {
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
    box-shadow: var(--shadow-strong), inset 0 2px 0 color-mix(in srgb, var(--accent) 45%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
  }

  .project-logo-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 2.5rem;
    padding: 0.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    padding: 0.2rem 0.6rem;
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 4px;
    border: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  .project-status--active   { color: #34c38f; border-color: rgba(52,195,143,0.3); background: rgba(52,195,143,0.08); }
  .project-status--completed{ color: var(--muted); background: var(--surface); }
  .project-status--ongoing  { color: #4c83ff; border-color: rgba(76,131,255,0.3); background: rgba(76,131,255,0.08); }
  .project-status--member   { color: #8090b8; border-color: rgba(128,144,184,0.3); background: rgba(128,144,184,0.08); }

  .project-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 500;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    background: var(--surface);
    font-family: 'JetBrains Mono', monospace;
  }

  .project-dl-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .project-dl-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 0.2rem;
  }
</style>
