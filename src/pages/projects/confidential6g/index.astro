---
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import ProjectInformation from "../../../components/ProjectInformation.astro";
import ProjectPartners from "../../../components/ProjectPartners.astro";
import Footer from "../../../components/Footer.astro";
---

<BaseLayout
  title="CONFIDENTIAL6G | Abstract Machines"
  description="Confidential Computing and Privacy-Preserving Technologies for 6G. Abstract Machines serves as Technical Manager on this EU Horizon Europe project."
>
  <Header />
  <main>

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="proj-hero">
      <div class="container-wide">
        <div class="proj-hero-inner">

          <div class="proj-kicker-row">
            <p class="section-label">EU Horizon Europe · Research Project</p>
            <span class="proj-status proj-status--completed">Completed</span>
          </div>

          <div class="proj-logo-wrap">
            <Image
              src="/img/logos/confidential6G.jpg"
              alt="CONFIDENTIAL6G project logo"
              width={400}
              height={160}
              loading="eager"
              decoding="async"
              class="proj-logo dark:brightness-[1.8]"
            />
          </div>

          <h1 class="proj-title">CONFIDENTIAL6G</h1>
          <p class="proj-subtitle">
            Confidential Computing and Privacy-Preserving Technologies for 6G
          </p>

          <dl class="proj-meta-strip">
            <div class="proj-meta-item">
              <dt class="proj-meta-label">Duration</dt>
              <dd class="proj-meta-val">2023–2025</dd>
            </div>
            <div class="proj-meta-item">
              <dt class="proj-meta-label">Budget</dt>
              <dd class="proj-meta-val">€5 Million</dd>
            </div>
            <div class="proj-meta-item">
              <dt class="proj-meta-label">Coordinator</dt>
              <dd class="proj-meta-val">WINGS ICT Solutions</dd>
            </div>
            <div class="proj-meta-item">
              <dt class="proj-meta-label">AM Role</dt>
              <dd class="proj-meta-val proj-meta-val--accent">Technical Manager</dd>
            </div>
          </dl>

          <div class="proj-hero-links">
            <a
              href="https://confidential6g.eu/"
              target="_blank"
              rel="noopener noreferrer"
              class="button-primary"
            >Visit Project Site ↗</a>
            <a
              href="https://cordis.europa.eu/project/id/101096435"
              target="_blank"
              rel="noopener noreferrer"
              class="button-secondary"
            >View on CORDIS ↗</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Body ──────────────────────────────────────────── -->
    <section class="proj-body">
      <div class="container-wide">
        <div class="proj-body-grid">

          <!-- ── Main content ──────────────────────────── -->
          <div class="proj-main">

            <div class="proj-section">
              <p class="section-label">Overview</p>
              <h2 class="proj-section-title">Project Description</h2>
              <p class="proj-text">
                In CONFIDENTIAL6G, the goal is to ensure secure and private
                computation in the cloud-edge continuum of 6G by developing
                modern cryptographic techniques, tools, and libraries. The
                project prioritises security enablers across heterogeneous
                environments and contexts, recognising that data privacy must be
                built into the architecture rather than added after the fact.
              </p>
              <p class="proj-text">
                A central challenge is the threat posed by near-future quantum
                computers capable of breaking contemporary encryption. The project
                addresses this through novel cryptographic operations and
                post-quantum networking protocols designed for 6G infrastructure.
              </p>
            </div>

            <div class="proj-section">
              <p class="section-label">Summary</p>
              <h2 class="proj-section-title">Project Summary</h2>
              <div class="proj-summary-grid">
                <div>
                  <p class="proj-sub-head">Key Objectives</p>
                  <ul class="proj-list">
                    <li><strong>Quantum-resistant security:</strong> Develop cryptographic libraries for 6G confidential computing and networking.</li>
                    <li><strong>Privacy-preserving AI/ML:</strong> Create secure, GDPR-compliant methods in multi-stakeholder environments.</li>
                    <li><strong>Edge-cloud networking:</strong> Build secure networking for confidential computing and federated machine learning.</li>
                    <li><strong>Modular framework:</strong> Integrate all tools and validate with real 6G use cases.</li>
                    <li><strong>Standardisation support:</strong> Advance 6G security standards and EU capabilities in future cloud technologies.</li>
                  </ul>
                </div>
                <div>
                  <p class="proj-sub-head">Expected Outcomes</p>
                  <ul class="proj-list">
                    <li><strong>Cryptographic libraries:</strong> Post-quantum libraries and SDKs for 6G.</li>
                    <li><strong>Computing framework:</strong> Confidential computing framework for cloud-edge environments.</li>
                    <li><strong>Privacy protocols:</strong> Privacy-preserving protocols for heterogeneous 6G networks.</li>
                    <li><strong>Security tools:</strong> Quantum-resistant security tools and artifacts.</li>
                    <li><strong>Security standards:</strong> Enhanced security standards for future 6G deployments.</li>
                  </ul>
                </div>
              </div>
            </div>

            <div class="proj-section">
              <p class="section-label">Contribution</p>
              <h2 class="proj-section-title">Our Involvement</h2>
              <p class="proj-text">
                Abstract Machines serves as the Technical Manager of the
                CONFIDENTIAL6G project, leading coordination of technical
                activities and ensuring successful delivery of project
                objectives. Our expertise in IoT infrastructure and security
                makes us well positioned to address the privacy challenges
                inherent in 6G networks.
              </p>
              <ul class="proj-list">
                <li><strong>Technical Management:</strong> Coordinating technical activities and ensuring project milestone delivery.</li>
                <li><strong>Secure IoT Integration:</strong> Developing privacy-preserving IoT protocols for 6G networks.</li>
                <li><strong>Edge Security:</strong> Implementing confidential computing at the network edge.</li>
                <li><strong>Platform Development:</strong> Creating secure platforms for privacy-preserving applications.</li>
                <li><strong>Cryptographic Implementation:</strong> Integrating advanced cryptographic protocols into IoT systems.</li>
              </ul>
            </div>

            <div class="proj-section">
              <p class="section-label">Research Focus</p>
              <h2 class="proj-section-title">Technical Work Areas</h2>
              <div class="proj-goal-grid">

                <div class="proj-goal-card card-base">
                  <svg class="proj-goal-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <rect x="3" y="9" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                    <path d="M7 9V6a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                    <circle cx="10" cy="13.5" r="1.5" fill="currentColor" opacity=".6"/>
                  </svg>
                  <h3 class="proj-goal-title">Cryptography</h3>
                  <p class="proj-goal-text">Cryptographic enablers for confidential computing (FHE, SMPC, TEE) and post-quantum networking. DLT privacy enablers (ZKP). Support for embedded edge devices and hardware security modules.</p>
                </div>

                <div class="proj-goal-card card-base">
                  <svg class="proj-goal-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <rect x="5" y="5" width="10" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                    <rect x="7.5" y="7.5" width="5" height="5" rx="0.75" fill="currentColor" opacity=".5"/>
                    <path d="M7 3v2M10 3v2M13 3v2M7 15v2M10 15v2M13 15v2M3 7h2M3 10h2M3 13h2M15 7h2M15 10h2M15 13h2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                  </svg>
                  <h3 class="proj-goal-title">Confidential Computing</h3>
                  <p class="proj-goal-text">Confidential computing via FHE, SMPC, and HW TEEs. Collaborative AI/ML. Confidential containers, remote attestations, secure enclave abstractions, and key distribution.</p>
                </div>

                <div class="proj-goal-card card-base">
                  <svg class="proj-goal-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M10 2L3.5 4.75V9.5C3.5 13.5 6.5 16.75 10 18C13.5 16.75 16.5 13.5 16.5 9.5V4.75L10 2Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                    <path d="M7.5 10l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <h3 class="proj-goal-title">Confidential Networking</h3>
                  <p class="proj-goal-text">Post-quantum secure network protocols. Secure data sharing and access control. Private blockchain smart contracts, DIDs and VCs. Federated AI/ML orchestration.</p>
                </div>

              </div>
            </div>

          </div>

          <!-- ── Sidebar ────────────────────────────────── -->
          <aside class="proj-sidebar">
            <ProjectInformation
              items={[
                { label: "Duration", value: "1 January 2023 – 31 December 2025" },
                { label: "Funding Program", value: "Horizon Europe" },
                { label: "Total Budget", value: "€5 Million" },
                { label: "Project Coordinator", value: "WINGS ICT Solutions Technologies" },
                { label: "AM Role", value: "Technical Manager" },
                { label: "Status", value: "Completed", pill: true },
              ]}
              links={[
                { label: "Visit Project Site", href: "https://confidential6g.eu/" },
                { label: "View on CORDIS", href: "https://cordis.europa.eu/project/id/101096435" },
              ]}
            />
            <ProjectPartners
              partners={[
                { alt: "Wings ICT", src: "/img/logos/wings-logo.png", logoClass: "dark:brightness-[1.3]" },
                { alt: "Nokia", src: "/img/logos/nokia-1.png" },
                { alt: "Nokia Bell Labs", src: "/img/logos/nokia-bellLabs.png" },
                { alt: "Telefonica", src: "/img/logos/telefonica.png" },
                { alt: "Eindhoven University (TU/e)", src: "/img/logos/tue.png" },
                { alt: "Ultraviolet", src: "/img/logos/ultraviolet.png" },
                { alt: "Zen", src: "/img/logos/zen.png", logoClass: "dark:invert !h-8" },
                { alt: "VTT", src: "/img/logos/vtt.png" },
                { alt: "TNO", src: "/img/logos/tno.png", logoClass: "dark:brightness-200 !h-5" },
                { alt: "IMDEA", src: "/img/logos/imdea.png" },
                { alt: "TU Graz", src: "/img/logos/tu-gratz.png" },
                { alt: "UCD", src: "/img/logos/ucd.png", logoClass: "dark:brightness-[1.3] !h-8" },
                { alt: "TU Wien", src: "/img/logos/tuw.png", logoClass: "dark:brightness-[1.3]" },
                { alt: "AMA", src: "/img/logos/AMA.png" },
              ]}
            />
          </aside>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ───────────────────────────────────────────── */
  .proj-hero {
    padding: clamp(3rem, 5vw, 5rem) 0 clamp(2.5rem, 4vw, 4rem);
    text-align: center;
  }

  .proj-hero-inner {
    max-width: 50rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .proj-kicker-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .proj-status {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  .proj-status--completed {
    color: var(--muted);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .proj-status--active {
    color: #34c38f;
    border: 1px solid rgba(52, 195, 143, 0.3);
    background: rgba(52, 195, 143, 0.08);
  }

  .proj-logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    margin: 0.25rem 0;
  }

  .proj-logo {
    height: 3.75rem;
    width: auto;
    max-width: 14rem;
    object-fit: contain;
    display: block;
  }

  .proj-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.06;
    color: var(--text);
  }

  .proj-subtitle {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--muted);
    line-height: 1.6;
    max-width: 44ch;
    margin-top: -0.25rem;
  }

  .proj-meta-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: 0.5rem 2.5rem;
    margin: 0.25rem 0;
    padding: 1rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    width: 100%;
  }

  .proj-meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .proj-meta-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    color: var(--muted);
    opacity: 0.7;
    line-height: 1;
  }

  .proj-meta-val {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .proj-meta-val--accent {
    color: var(--accent);
  }

  .proj-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.25rem;
  }

  /* ── Body layout ────────────────────────────────────── */
  .proj-body {
    padding: clamp(2.5rem, 4vw, 4rem) 0 clamp(3.5rem, 6vw, 6rem);
  }

  .proj-body-grid {
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .proj-body-grid {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    }
  }

  /* ── Main content ───────────────────────────────────── */
  .proj-main {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .proj-section {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .proj-section-title {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 0.2rem;
  }

  .proj-text {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.8;
    max-width: 72ch;
    margin-top: 0.35rem;
  }

  .proj-list {
    list-style: none;
    padding: 0;
    margin: 0.65rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .proj-list li {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
    padding-left: 1.35rem;
    position: relative;
  }

  .proj-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
    opacity: 0.65;
    font-style: normal;
  }

  .proj-summary-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 0.65rem;
  }

  @media (min-width: 640px) {
    .proj-summary-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .proj-sub-head {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 0.15rem;
  }

  /* ── Goal cards ─────────────────────────────────────── */
  .proj-goal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
    margin-top: 0.65rem;
  }

  @media (min-width: 640px) {
    .proj-goal-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .proj-goal-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .proj-goal-icon {
    color: var(--accent);
    opacity: 0.75;
    flex-shrink: 0;
  }

  .proj-goal-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .proj-goal-text {
    font-size: 0.825rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ── Sidebar ────────────────────────────────────────── */
  .proj-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: 5rem;
  }

  @media (max-width: 1023px) {
    .proj-sidebar {
      position: static;
    }
  }
</style>
