---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroBig from "../../components/HeroBig.astro";
import Section from "../../components/Section.astro";
import FinalCTA from "../../components/FinalCTA.astro";

type Icon = { paths: string[] };

type ServiceCard = {
  title: string;
  description: string;
  points: string[];
  icon: Icon;
};

type ProcessStep = {
  number: string;
  title: string;
  description: string;
};

type PricingPlan = {
  title: string;
  description: string;
  metaLabel: string;
  metaValue: string;
  badge?: string;
  ctaLabel?: string;
  href?: string;
  icon: Icon;
};

const icons = {
  managed: {
    paths: [
      "M4 6h16",
      "M4 10h16",
      "M4 14h10",
      "M4 18h10",
      "M16 14h4v6h-4z",
      "M18 14v-2",
    ],
  },
  dev: {
    paths: ["M8 9l-3 3 3 3", "M16 9l3 3-3 3", "M10 19l4-14"],
  },
  consulting: {
    paths: [
      "M12 3l7 4v6c0 5-3 9-7 10-4-1-7-5-7-10V7l7-4z",
      "M9.5 12l1.7 1.7L14.8 10",
    ],
  },
  training: {
    paths: [
      "M22 10l-10 5L2 10l10-5 10 5z",
      "M6 12v5c0 1 3 3 6 3s6-2 6-3v-5",
    ],
  },
  pricing: {
    paths: [
      "M12 1v22",
      "M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6",
    ],
  },
  contact: {
    paths: [
      "M21 11.5a8.5 8.5 0 1 1-3.2-6.6",
      "M21 3v6h-6",
      "M8 12h8",
      "M8 16h5",
    ],
  },
} satisfies Record<string, Icon>;

const serviceCards: ServiceCard[] = [
  {
    title: "Managed Deployments",
    description: "End-to-end deployment and operations.",
    points: [
      "Infrastructure setup and configuration",
      "24/7 monitoring and support",
      "Performance optimization",
      "Security updates and patches",
      "Backup and disaster recovery",
      "SLA guarantees",
    ],
    icon: icons.managed,
  },
  {
    title: "Custom Development",
    description: "Tailored solutions for unique requirements.",
    points: [
      "Custom protocol implementations",
      "Integration with existing systems",
      "Feature development and extensions",
      "Custom hardware firmware",
      "API design and development",
      "Performance-critical optimizations",
    ],
    icon: icons.dev,
  },
  {
    title: "Consulting & Architecture",
    description: "Expert guidance for your infrastructure.",
    points: [
      "Architecture design and review",
      "Technology stack selection",
      "Security audit and hardening",
      "Scalability planning",
      "Migration strategies",
      "Best practices implementation",
    ],
    icon: icons.consulting,
  },
  {
    title: "Training & Support",
    description: "Empower your team with expertise.",
    points: [
      "On-site and remote training",
      "Documentation and runbooks",
      "Technical workshops",
      "Dedicated support channels",
      "Knowledge transfer sessions",
      "Community support access",
    ],
    icon: icons.training,
  },
];

const processSteps: ProcessStep[] = [
  {
    number: "01",
    title: "Discovery",
    description:
      "We analyze your requirements, existing infrastructure, and business goals to design the optimal solution.",
  },
  {
    number: "02",
    title: "Planning",
    description:
      "Create detailed technical specifications, timeline, and resource allocation for your project.",
  },
  {
    number: "03",
    title: "Implementation",
    description:
      "Execute development and deployment with regular updates and milestone reviews.",
  },
  {
    number: "04",
    title: "Support",
    description:
      "Ongoing maintenance, monitoring, and optimization to ensure peak performance.",
  },
];

const pricingPlans: PricingPlan[] = [
  {
    title: "Project-Based",
    description: "Fixed scope and timeline with clear deliverables.",
    metaLabel: "Fixed",
    metaValue: "One-time investment",
    ctaLabel: "Request quote",
    href: "/contact/",
    icon: icons.pricing,
  },
  {
    title: "Retainer",
    description: "Ongoing support with predictable monthly costs.",
    metaLabel: "Monthly",
    metaValue: "Continuous partnership",
    badge: "Popular",
    ctaLabel: "Start retainer",
    href: "/contact/",
    icon: icons.pricing,
  },
  {
    title: "Time & Materials",
    description: "Flexible engagement for evolving requirements.",
    metaLabel: "Hourly",
    metaValue: "Maximum flexibility",
    ctaLabel: "Talk hourly",
    href: "/contact/",
    icon: icons.pricing,
  },
  {
    title: "Not sure yet?",
    description: "Tell us your goals. We'll recommend the best engagement model.",
    metaLabel: "Contact",
    metaValue: "Get advice",
    ctaLabel: "Get in touch",
    href: "/contact/",
    icon: icons.contact,
  },
];
---

<BaseLayout
  title="Services | Abstract Machines"
  description="From deployment to development, we provide comprehensive support for your infrastructure needs."
>
  <Header />
  <main>
    <HeroBig
      title="Services Built on Experience"
      subtitle="From deployment to development, we provide comprehensive support for your infrastructure needs"
      backgroundClass="hero-grid"
    />

    <section class="py-16">
      <div class="container-wide">
        <div class="grid gap-6 md:grid-cols-2">
          {
            serviceCards.map((card) => (
              <article class="card-base">
                <div class="flex items-start gap-4">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-subtle bg-surface-2 text-accent">
                    <svg
                      class="h-6 w-6"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      {card.icon.paths.map((d) => (
                        <path d={d}></path>
                      ))}
                    </svg>
                  </div>
                  <div class="min-w-0">
                    <h3 class="text-xl font-semibold">{card.title}</h3>
                    <p class="mt-2 text-muted">{card.description}</p>
                  </div>
                </div>

                <ul class="mt-5 space-y-2 text-sm text-muted">
                  {card.points.map((point) => (
                    <li class="flex items-start gap-2">
                      <svg
                        class="mt-0.5 h-4 w-4 flex-none text-accent"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M20 6L9 17l-5-5"></path>
                      </svg>
                      <span>{point}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <Section
      title="Our Process"
      subtitle="A proven approach to delivering results"
      center
    >
      <div class="relative">
        <div class="hidden lg:block absolute left-0 right-0 top-6 h-px bg-[color:var(--border)]"></div>
        <div class="lg:hidden absolute left-5 top-6 bottom-6 w-px bg-[color:var(--border)]"></div>
        <ol class="relative grid gap-6 lg:grid-cols-4">
          {
            processSteps.map((step) => (
              <li class="card-base">
                <div class="flex items-start gap-4">
                  <span class="relative z-10 flex h-10 w-10 flex-none items-center justify-center rounded-full border border-subtle bg-surface-2 font-semibold text-primary">
                    {step.number}
                  </span>
                  <div class="min-w-0">
                    <h3 class="text-lg font-semibold">{step.title}</h3>
                    <p class="mt-2 text-muted">{step.description}</p>
                  </div>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </Section>

    <Section
      title="Transparent Pricing"
      subtitle="Flexible engagement models to match your needs"
      center
    >
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          pricingPlans.map((plan) => (
            <article
              class={`card-base relative flex h-full flex-col ${plan.badge ? "border-[color:var(--accent)]" : ""}`}
            >
              {plan.badge && (
                <span class="absolute right-5 top-5 rounded-full bg-[color:var(--accent)] px-3 py-1 text-xs font-semibold text-[color:var(--accent-contrast)]">
                  {plan.badge}
                </span>
              )}

              <div class="flex min-h-[9rem] items-start gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-subtle bg-surface-2 text-accent">
                  <svg
                    class="h-6 w-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    {plan.icon.paths.map((d) => (
                      <path d={d}></path>
                    ))}
                  </svg>
                </div>
                <div class="min-w-0">
                  <h3 class="text-xl font-semibold">{plan.title}</h3>
                  <p class="mt-2 text-muted">{plan.description}</p>
                </div>
              </div>

              <div class="mt-auto rounded-xl border border-subtle bg-surface-2 px-4 py-2.5 text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted">
                  {plan.metaLabel}
                </p>
                <p class="mt-0.5 text-base font-semibold leading-tight text-primary">
                  {plan.metaValue}
                </p>
              </div>

              <div class="mt-3 flex items-center justify-center">
                {plan.ctaLabel && plan.href && (
                  <a class="inline-flex font-semibold text-accent" href={plan.href}>
                    {plan.ctaLabel} →
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </Section>

    <FinalCTA
      title="Ready to Get Started?"
      subtitle="Let's discuss how we can help you build better infrastructure"
      primary={{ label: "Schedule a call", href: "/contact/", external: false }}
      secondary={{ label: "View our work", href: "/projects/", external: false }}
    />
  </main>
  <Footer />
</BaseLayout>
