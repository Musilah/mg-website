---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import HeroBig from "../../components/HeroBig.astro";
import Section from "../../components/Section.astro";
import FinalCTA from "../../components/FinalCTA.astro";

type ServiceCard = {
  title: string;
  description: string;
  points: string[];
  icon: string[];
};

type ProcessStep = {
  number: string;
  title: string;
  description: string;
};

const serviceCards: ServiceCard[] = [
  {
    title: "Managed Deployments",
    description: "End-to-end deployment and operations for your infrastructure.",
    points: [
      "Infrastructure setup and configuration",
      "Monitoring and alerting",
      "Performance optimization",
      "Security updates and patch management",
      "Backup and disaster recovery",
      "SLA-backed support",
    ],
    icon: ["M4 6h16", "M4 10h16", "M4 14h10", "M4 18h10", "M16 14h4v6h-4z", "M18 14v-2"],
  },
  {
    title: "Custom Development",
    description: "Tailored software for unique integration and extension requirements.",
    points: [
      "Custom protocol implementations",
      "Integration with existing systems",
      "Feature development and extensions",
      "Custom hardware firmware",
      "API design and development",
      "Performance-critical optimizations",
    ],
    icon: ["M8 9l-3 3 3 3", "M16 9l3 3-3 3", "M10 19l4-14"],
  },
  {
    title: "Architecture & Consulting",
    description: "Expert guidance for infrastructure design and security.",
    points: [
      "Architecture design and review",
      "Technology stack selection",
      "Security audit and hardening",
      "Scalability planning",
      "Migration strategies",
      "Best practices and runbooks",
    ],
    icon: ["M12 3l7 4v6c0 5-3 9-7 10-4-1-7-5-7-10V7l7-4z", "M9.5 12l1.7 1.7L14.8 10"],
  },
  {
    title: "Training & Support",
    description: "Empower your team to operate and extend the stack independently.",
    points: [
      "On-site and remote training",
      "Documentation and runbooks",
      "Technical workshops",
      "Dedicated support channels",
      "Knowledge transfer sessions",
      "Community support access",
    ],
    icon: ["M22 10l-10 5L2 10l10-5 10 5z", "M6 12v5c0 1 3 3 6 3s6-2 6-3v-5"],
  },
];

const processSteps: ProcessStep[] = [
  {
    number: "01",
    title: "Discovery",
    description: "We review your requirements, existing stack, and goals to scope the right engagement.",
  },
  {
    number: "02",
    title: "Planning",
    description: "Technical specifications, timeline, and resource allocation — agreed before work begins.",
  },
  {
    number: "03",
    title: "Delivery",
    description: "Iterative development and deployment with regular milestone reviews.",
  },
  {
    number: "04",
    title: "Support",
    description: "Ongoing maintenance, monitoring, and optimisation to keep things running well.",
  },
];

const engagementModels = [
  {
    title: "Project-Based",
    description: "Fixed scope and timeline with clear deliverables. Good for well-defined integrations or builds.",
    meta: "One-time",
  },
  {
    title: "Retainer",
    description: "Ongoing support and development at a predictable monthly cost. Most common engagement.",
    meta: "Monthly",
    popular: true,
  },
  {
    title: "Time & Materials",
    description: "Flexible engagement for evolving requirements or exploratory work.",
    meta: "Hourly",
  },
];
---

<BaseLayout
  title="Services | Abstract Machines"
  description="Deployment, development, architecture, and training services for Magistrala and the Abstract Machines infrastructure stack."
>
  <Header />
  <main>
    <HeroBig
      kicker="Services"
      title="Built on experience, not boilerplate."
      subtitle="We deploy, extend, and maintain the Abstract Machines stack for production environments. Every engagement is with the engineers who built it."
    />

    <Section title="What we do" subtitle="Four engagement types, scoped to your needs.">
      <div class="grid gap-5 md:grid-cols-2">
        {serviceCards.map((card) => (
          <article class="card-base">
            <div class="flex items-start gap-3 mb-4">
              <svg
                class="h-5 w-5 text-accent flex-shrink-0 mt-0.5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {card.icon.map((d) => <path d={d} />)}
              </svg>
              <div>
                <h3 class="text-base font-semibold">{card.title}</h3>
                <p class="mt-1 text-sm text-muted">{card.description}</p>
              </div>
            </div>
            <ul class="space-y-1.5">
              {card.points.map((point) => (
                <li class="flex items-start gap-2 text-sm text-muted">
                  <svg class="mt-0.5 h-3.5 w-3.5 flex-none text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Section>

    <Section title="How we work" subtitle="A consistent process, regardless of engagement type." center>
      <ol class="process-list">
        {processSteps.map((step) => (
          <li class="process-item">
            <span class="process-number" aria-hidden="true">{step.number}</span>
            <div>
              <h3 class="process-title">{step.title}</h3>
              <p class="process-body">{step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </Section>

    <Section title="Engagement models" subtitle="Flexible structures to match your situation." center>
      <div class="engagement-grid">
        {engagementModels.map((model) => (
          <article class={`engagement-card card-base${model.popular ? " engagement-card--popular" : ""}`}>
            {model.popular && <span class="engagement-popular-badge">Most common</span>}
            <div class="engagement-meta">{model.meta}</div>
            <h3 class="engagement-title">{model.title}</h3>
            <p class="engagement-desc">{model.description}</p>
            <a href="/contact/" class="engagement-cta">Get in touch →</a>
          </article>
        ))}
        <article class="engagement-card engagement-card--cta card-base">
          <div class="engagement-meta">Not sure?</div>
          <h3 class="engagement-title">Tell us your goal</h3>
          <p class="engagement-desc">We'll recommend the right engagement model for your situation.</p>
          <a href="/contact/" class="engagement-cta">Start the conversation →</a>
        </article>
      </div>
    </Section>

    <FinalCTA
      title="Ready to talk?"
      subtitle={null}
      primary={{ label: "Get in touch", href: "/contact/", external: false }}
      secondary={{ label: "View our projects", href: "/projects/", external: false }}
    />
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Process steps ────────────────────────────────────── */
  .process-list {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 44rem;
    display: grid;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--panel);
  }

  .process-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .process-item:last-child { border-bottom: none; }

  .process-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent);
    opacity: 0.65;
    padding-top: 0.2rem;
    flex-shrink: 0;
    min-width: 2rem;
  }

  .process-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .process-body {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
    margin-top: 0.2rem;
  }

  /* ── Engagement models ────────────────────────────────── */
  .engagement-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
    max-width: 56rem;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .engagement-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .engagement-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .engagement-card--popular {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
  }

  .engagement-card--cta {
    border-style: dashed;
  }

  .engagement-popular-badge {
    position: absolute;
    top: -0.65rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    padding: 0.15rem 0.6rem;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: 3px;
    white-space: nowrap;
  }

  .engagement-meta {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .engagement-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .engagement-desc {
    font-size: 0.825rem;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }

  .engagement-cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.25rem;
  }

  .engagement-cta:hover { opacity: 0.72; }
</style>
