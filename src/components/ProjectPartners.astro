---
import { Image } from "astro:assets";

const { title = "Project Partners", partners = [], logoClass = "" } =
  Astro.props;
---

<div class="card-base project-partners">
  <div class="border-b border-subtle pb-4">
    <p class="section-label">Network</p>
    <h3 class="mt-1 text-xl font-semibold text-primary">{title}</h3>
    <p class="mt-1 text-base text-muted">
      Organizations collaborating across this project.
    </p>
  </div>

  <div class="mt-5 grid grid-cols-2 items-stretch gap-3">
    {
      partners.map((partner, index) => (
        <div class="partner-tile flex w-full items-center justify-center rounded-xl p-3">
          <Image
            alt={partner.alt}
            src={partner.src}
            class={[
              "h-9 w-auto max-w-full object-contain sm:h-10",
              logoClass,
              partner.logoClass,
            ]
              .filter(Boolean)
              .join(" ")}
            width={280}
            height={100}
            loading={index < 2 ? "eager" : "lazy"}
            decoding="async"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .project-partners {
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--panel) 74%, transparent),
      color-mix(in srgb, var(--surface) 78%, transparent)
    );
    border-color: color-mix(
      in srgb,
      var(--border) 84%,
      rgba(255, 255, 255, 0.2)
    );
    backdrop-filter: blur(14px) saturate(145%);
    -webkit-backdrop-filter: blur(14px) saturate(145%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, #fff 22%, transparent),
      var(--shadow-soft);
  }

  .partner-tile {
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 76%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, #fff 14%, transparent);
    min-height: 4.75rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .partner-tile:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, #fff 14%, transparent),
      var(--shadow-soft);
  }
</style>
