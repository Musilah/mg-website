---
import { Image } from "astro:assets";

const navItems = [
  { label: "Products", href: "/products", external: false },
  { label: "Projects", href: "/projects", external: false },
  { label: "Company", href: "/company", external: false },
  { label: "Blog", href: "/blog", external: false },
];
---

<header class="site-header">
  <div class="container-wide">
    <nav class="flex items-center justify-between h-14" aria-label="Primary">
      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0 text-primary" aria-label="Abstract Machines">
        <Image
          src="/img/logos/abstract-machines_logo_landscape-black.png"
          alt="Abstract Machines"
          width={200}
          height={24}
          priority
          class="header-logo block h-auto w-auto max-h-[22px] max-w-[min(200px,50vw)] object-contain"
        />
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-6 text-sm lg:flex" role="list">
        {navItems.map((item) => (
          <li>
            <a
              class="nav-link font-medium whitespace-nowrap"
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="https://github.com/absmach"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abstract Machines on GitHub"
            class="github-link"
          >
            <svg fill="currentColor" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <title>GitHub</title>
              <path d="M12 0c6.63 0 12 5.276 12 11.79-.001 5.067-3.29 9.567-8.175 11.187-.6.118-.825-.25-.825-.56 0-.398.015-1.665.015-3.242 0-1.105-.375-1.813-.81-2.181 2.67-.295 5.475-1.297 5.475-5.822 0-1.297-.465-2.344-1.23-3.169.12-.295.54-1.503-.12-3.125 0 0-1.005-.324-3.3 1.209a11.32 11.32 0 00-3-.398c-1.02 0-2.04.133-3 .398-2.295-1.518-3.3-1.209-3.3-1.209-.66 1.622-.24 2.83-.12 3.125-.765.825-1.23 1.887-1.23 3.169 0 4.51 2.79 5.527 5.46 5.822-.345.294-.66.81-.765 1.577-.69.31-2.415.81-3.495-.973-.225-.354-.9-1.223-1.845-1.209-1.005.015-.405.56.015.781.51.28 1.095 1.327 1.23 1.666.24.663 1.02 1.93 4.035 1.385 0 .988.015 1.916.015 2.196 0 .31-.225.664-.825.56C3.303 21.374-.003 16.867 0 11.791 0 5.276 5.37 0 12 0z"/>
            </svg>
          </a>
        </li>
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-label="Toggle theme"
        >
          <span class="theme-toggle-icon theme-toggle-icon--sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4.25"></circle>
              <path d="M12 2.75v2.1M12 19.15v2.1M4.93 4.93l1.48 1.48M17.59 17.59l1.48 1.48M2.75 12h2.1M19.15 12h2.1M4.93 19.07l1.48-1.48M17.59 6.41l1.48-1.48"></path>
            </svg>
          </span>
          <span class="theme-toggle-icon theme-toggle-icon--moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.37 14.95A8.58 8.58 0 0 1 9.05 3.63a.6.6 0 0 0-.74-.74A9.8 9.8 0 1 0 21.1 15.69a.6.6 0 0 0-.73-.74Z"></path>
            </svg>
          </span>
          <span class="theme-toggle-label">Theme</span>
        </button>
        <a href="/contact/" class="button-primary">Contact us</a>
      </div>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-md p-2 text-muted hover:text-primary hover:bg-surface transition-colors lg:hidden"
        aria-label="Open menu"
        aria-controls="site-menu"
        aria-expanded="false"
        data-mobile-menu-open
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="site-menu"
  class="fixed inset-0 z-[70] hidden lg:hidden"
  aria-hidden="true"
  data-mobile-menu
>
  <div
    class="absolute inset-0 bg-black/40 backdrop-blur-sm opacity-0 transition-opacity duration-200 motion-reduce:transition-none"
    data-mobile-menu-overlay
    data-mobile-menu-close
  ></div>
  <aside
    class="absolute left-0 top-0 h-full w-[min(18rem,85vw)] overflow-hidden bg-[color:var(--drawer-bg)] border-r border-subtle -translate-x-full transition-transform duration-300 ease-out motion-reduce:transition-none"
    role="dialog"
    aria-modal="true"
    aria-label="Site menu"
    data-mobile-menu-panel
  >
    <div class="flex items-center justify-between border-b border-subtle px-5 py-4">
      <span class="text-sm font-semibold tracking-tight">Menu</span>
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-md p-1.5 text-muted hover:text-primary hover:bg-surface transition-colors"
        aria-label="Close menu"
        data-mobile-menu-close
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
    </div>
    <nav class="px-4 py-4">
      <div class="mb-4 flex items-center justify-between border-b border-subtle px-4 pb-4">
        <span class="text-sm font-medium text-muted">Appearance</span>
        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-label="Toggle theme"
        >
          <span class="theme-toggle-icon theme-toggle-icon--sun" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4.25"></circle>
              <path d="M12 2.75v2.1M12 19.15v2.1M4.93 4.93l1.48 1.48M17.59 17.59l1.48 1.48M2.75 12h2.1M19.15 12h2.1M4.93 19.07l1.48-1.48M17.59 6.41l1.48-1.48"></path>
            </svg>
          </span>
          <span class="theme-toggle-icon theme-toggle-icon--moon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.37 14.95A8.58 8.58 0 0 1 9.05 3.63a.6.6 0 0 0-.74-.74A9.8 9.8 0 1 0 21.1 15.69a.6.6 0 0 0-.73-.74Z"></path>
            </svg>
          </span>
          <span class="theme-toggle-label">Theme</span>
        </button>
      </div>
      <ul class="space-y-0.5" role="list">
        {navItems.map((item) => (
          <li>
            <a
              class="block rounded-lg px-4 py-3 text-sm font-medium text-primary hover:bg-surface transition-colors"
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
              data-mobile-menu-link
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a
            class="block rounded-lg px-4 py-3 text-sm font-medium text-primary hover:bg-surface transition-colors"
            href="https://github.com/absmach"
            target="_blank"
            rel="noopener noreferrer"
            data-mobile-menu-link
          >
            GitHub ↗
          </a>
        </li>
      </ul>
      <div class="mt-4 pt-4 border-t border-subtle">
        <a href="/contact/" class="button-primary w-full justify-center" data-mobile-menu-link>Contact us</a>
      </div>
    </nav>
  </aside>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel) 88%, transparent);
    color: var(--text);
    transition:
      border-color 150ms ease,
      background-color 150ms ease,
      color 150ms ease;
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    border-color: color-mix(in srgb, var(--accent) 48%, var(--border-strong));
    color: var(--accent);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 45%, transparent);
    outline-offset: 2px;
  }

  .theme-toggle-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
  }

  .theme-toggle-icon svg {
    width: 100%;
    height: 100%;
  }

  .theme-toggle-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  :root[data-theme="light"] .theme-toggle-icon--moon {
    display: none;
  }

  :root[data-theme="dark"] .theme-toggle-icon--sun {
    display: none;
  }
</style>

<script is:inline>
  (() => {
    const menu = document.querySelector("[data-mobile-menu]");
    const openButton = document.querySelector("[data-mobile-menu-open]");
    if (!menu || !openButton) return;

    const overlay = menu.querySelector("[data-mobile-menu-overlay]");
    const panel = menu.querySelector("[data-mobile-menu-panel]");
    const closeButtons = menu.querySelectorAll("[data-mobile-menu-close]");
    const links = menu.querySelectorAll("[data-mobile-menu-link]");

    let isOpen = false;
    let lastFocused = null;
    let previousOverflow = "";

    const setOpen = (nextOpen) => {
      if (nextOpen === isOpen) return;
      isOpen = nextOpen;

      if (isOpen) {
        lastFocused = document.activeElement;
        previousOverflow = document.documentElement.style.overflow;
        document.documentElement.style.overflow = "hidden";
        menu.classList.remove("hidden");
        menu.setAttribute("aria-hidden", "false");
        openButton.setAttribute("aria-expanded", "true");
        requestAnimationFrame(() => {
          overlay?.classList.remove("opacity-0");
          overlay?.classList.add("opacity-100");
          panel?.classList.remove("-translate-x-full");
          panel?.classList.add("translate-x-0");
        });
        const focusTarget = panel?.querySelector("button, a, [tabindex]:not([tabindex='-1'])");
        focusTarget?.focus?.();
        return;
      }

      openButton.setAttribute("aria-expanded", "false");
      menu.setAttribute("aria-hidden", "true");
      document.documentElement.style.overflow = previousOverflow;
      overlay?.classList.remove("opacity-100");
      overlay?.classList.add("opacity-0");
      panel?.classList.remove("translate-x-0");
      panel?.classList.add("-translate-x-full");

      const finish = () => {
        menu.classList.add("hidden");
        if (lastFocused && typeof lastFocused.focus === "function") {
          lastFocused.focus();
        } else {
          openButton.focus();
        }
      };

      if (!panel) return finish();
      const fallback = window.setTimeout(finish, 350);
      panel.addEventListener("transitionend", () => {
        window.clearTimeout(fallback);
        finish();
      }, { once: true });
    };

    openButton.addEventListener("click", () => setOpen(true));
    closeButtons.forEach((b) => b.addEventListener("click", () => setOpen(false)));
    links.forEach((l) => l.addEventListener("click", () => setOpen(false)));
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") setOpen(false); });

    const mq = window.matchMedia("(min-width: 1024px)");
    const handleChange = (e) => { if (e.matches) setOpen(false); };
    if (mq.addEventListener) mq.addEventListener("change", handleChange);
    else if (mq.addListener) mq.addListener(handleChange);
  })();
</script>
