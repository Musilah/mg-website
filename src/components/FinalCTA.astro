---
type CtaLink = { label: string; href: string; external?: boolean };

const {
  title = "Build secure cloud–edge systems with us.",
  subtitle = "Work with us to design a solution that fits your infrastructure.",
  primary = { label: "Contact Us", href: "/contact/", external: false },
  secondary = { label: "Explore Products", href: "#products", external: false },
} = Astro.props as {
  title?: string;
  subtitle?: string;
  primary?: CtaLink;
  secondary?: CtaLink | null;
};
---

<section class="cta-section">
  <div class="container-wide">
    <div class="cta-inner">
      <div class="cta-copy">
        <h2 class="cta-title">{title}</h2>
        {subtitle && <p class="cta-subtitle">{subtitle}</p>}
      </div>
      <div class="cta-actions">
        {primary && (
          <a
            class="button-primary"
            href={primary.href}
            target={primary.external ? "_blank" : undefined}
            rel={primary.external ? "noopener noreferrer" : undefined}
          >
            {primary.label}
          </a>
        )}
        {secondary && (
          <a
            class="button-secondary"
            href={secondary.href}
            target={secondary.external ? "_blank" : undefined}
            rel={secondary.external ? "noopener noreferrer" : undefined}
          >
            {secondary.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: clamp(3.5rem, 6vw, 5.5rem) 0;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 48ch;
    margin-inline: auto;
    gap: 1.5rem;
  }

  .cta-copy {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cta-title {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--text);
  }

  .cta-subtitle {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }
</style>
