  .audio-select {
    padding: 0.4rem 0.48rem;
    border-radius: 0.72rem;
    color: var(--text);
    color-scheme: light;
  }

  .audio-select option,
  .audio-select optgroup {
    color: #0f172a;
    background: #ffffff;
  }

  :root[data-theme="dark"] .audio-select {
    color: color-mix(in srgb, #fff 92%, var(--text));
    color-scheme: light;
  }

  :root[data-theme="dark"] .audio-select option,
  :root[data-theme="dark"] .audio-select optgroup {
    color: #e8eef8;
    background: #0f172a;
  }

  #ar-rate {
    width: 4.6rem;
