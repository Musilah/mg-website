  .audio-settings-btn {
    color: color-mix(in srgb, var(--muted) 84%, var(--text));
    flex: 0 0 auto;
  }

  .audio-settings-icon {
    width: 1.05rem;
    height: 1.05rem;
  }

  .audio-settings-btn.is-open {
    color: color-mix(in srgb, var(--accent) 72%, var(--text));
    border-color: color-mix(in srgb, var(--accent) 56%, var(--border));
    background: color-mix(in srgb, var(--accent) 18%, var(--surface-2));
  }

  .audio-settings-panel {
    position: absolute;
    right: 2.9rem;
    bottom: calc(100% + 0.55rem);
    top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.78rem;
    border: 1px solid
      color-mix(in srgb, var(--border) 90%, transparent);
    background: color-mix(in srgb, var(--panel) 98%, var(--surface));
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.2);
    opacity: 0;
    pointer-events: none;
    transform: translateY(0.2rem) scale(0.98);
    transform-origin: bottom right;
    transition:
      opacity 0.16s ease,
      transform 0.16s ease;
    z-index: 20;
  }

  .audio-settings-panel.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .audio-reader-shell::-webkit-scrollbar {
    height: 0;
  }

  .audio-reader-shell {
    scrollbar-width: none;
    overflow: visible;
    position: relative;
    isolation: isolate;
    border-color: color-mix(
      in srgb,
      var(--border) 66%,
      rgba(255, 255, 255, 0.4)
    );
    background:
      linear-gradient(
        140deg,
        color-mix(in srgb, var(--panel) 50%, rgba(255, 255, 255, 0.46)),
        color-mix(in srgb, var(--surface) 52%, rgba(255, 255, 255, 0.2)) 52%,
        color-mix(in srgb, var(--panel) 60%, transparent)
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.18),
        rgba(255, 255, 255, 0) 40%
      );
    backdrop-filter: blur(24px) saturate(178%);
    -webkit-backdrop-filter: blur(24px) saturate(178%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.64),
      inset 0 -1px 0 rgba(255, 255, 255, 0.26),
      0 2px 10px rgba(15, 23, 42, 0.08),
      0 18px 40px rgba(15, 23, 42, 0.18);
  }

  .audio-reader-shell.is-floating {
    position: sticky;
    top: 6.25rem;
  }

  .audio-reader-shell.is-settings-open {
    z-index: 70;
  }

  .audio-reader-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background:
      linear-gradient(
        120deg,
        rgba(255, 255, 255, 0.26),
        rgba(255, 255, 255, 0) 46%
      ),
      radial-gradient(
        120% 110% at 4% 0%,
        rgba(255, 255, 255, 0.26),
        transparent 42%
      );
