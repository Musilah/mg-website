    color: #ffffff;
    background:
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--accent) 48%, var(--surface-2)),
        color-mix(in srgb, var(--surface) 52%, transparent)
      );
    border-color: color-mix(in srgb, var(--accent) 62%, rgba(255, 255, 255, 0.34));
    box-shadow:
