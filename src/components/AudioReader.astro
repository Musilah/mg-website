    background: linear-gradient(
      90deg,
      var(--ar-fill-color) 0%,
      var(--ar-fill-color) var(--ar-fill),
      var(--ar-track-color) var(--ar-fill),
      var(--ar-track-color) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.35),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }

  .audio-glass-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    margin-top: -5px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 65%, #fff);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .audio-glass-range::-moz-range-track {
