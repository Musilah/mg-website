</style>

<style is:global>
  .ar-highlight-root {
    position: relative;
  }

  .ar-highlight-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .ar-highlight-chip {
    position: absolute;
    border-radius: 0.35rem;
    background: color-mix(in srgb, var(--accent) 26%, transparent);
    box-shadow: inset 0 0 0 1px
      color-mix(in srgb, var(--accent) 44%, transparent);
    transition:
      top 0.12s ease,
      left 0.12s ease,
      width 0.12s ease,
      height 0.12s ease;
  }
</style>

<script define:vars={{ target }}>
  (() => {
    const btnToggle = document.getElementById("ar-toggle");
    const btnToggleLabel = document.getElementById("ar-toggle-label");
    const btnMute = document.getElementById("ar-mute");
    const btnSettings = document.getElementById("ar-settings");
    const btnPin = document.getElementById("ar-pin");
    const settingsPanelEl = document.getElementById("ar-settings-panel");
    const shellEl = document.getElementById("ar-shell");
    const iconPlay = document.getElementById("ar-icon-play");
    const iconPause = document.getElementById("ar-icon-pause");
    const iconVolume = document.getElementById("ar-icon-volume");
    const iconMuted = document.getElementById("ar-icon-muted");
    const iconPin = document.getElementById("ar-icon-pin");
    const iconUnpin = document.getElementById("ar-icon-unpin");
    const rateEl = document.getElementById("ar-rate");
    const voiceEl = document.getElementById("ar-voice");
    const seekEl = document.getElementById("ar-seek");
    const currentTimeEl = document.getElementById("ar-current-time");
    const totalTimeEl = document.getElementById("ar-total-time");
    const statusEl = document.getElementById("ar-status");
    const pinLabelEl = document.getElementById("ar-pin-label");

    const BASE_WPM = 165;

    let root = null;
    let voices = [];
    let prepared = false;

    let sentences = [];
    let sentenceWordOffsets = [];
    let totalWords = 0;
    let highlightLayer = null;

    let currentSentenceIndex = -1;
    let playheadSentenceIndex = 0;
    let hasCompleted = false;
    let activeUtterance = null;
    let isUserPaused = false;
    let isMuted = false;
    let isPinned = false;
    let hasManualPinOverride = false;
    let isSettingsOpen = false;

    let sessionId = 0;

    const setStatus = (message) => {
      if (statusEl) statusEl.textContent = message;
    };

    const getSupportsSpeech = () =>
      typeof window !== "undefined" && "speechSynthesis" in window;

    const getRateValue = () => {
      const raw = Number(rateEl?.value || "1.1");
      if (!Number.isFinite(raw)) return 1.1;
      return Math.max(0.5, Math.min(2, raw));
    };

    const wordsToSeconds = (words) => {
      const rate = getRateValue();
      if (rate <= 0) return 0;
      return (Math.max(0, words) * 60) / (BASE_WPM * rate);
    };

    const formatTime = (seconds) => {
      const safe = Math.max(0, Math.round(seconds));
      const minutes = Math.floor(safe / 60);
      const remaining = safe % 60;
      return `${String(minutes).padStart(2, "0")}:${String(remaining).padStart(2, "0")}`;
    };

    const getWordOffsetForSentence = (index) => {
      if (!sentences.length) return 0;
      const clamped = Math.max(0, Math.min(sentences.length - 1, index));
      return sentenceWordOffsets[clamped] ?? 0;
    };

    const updateTimeUiForSentence = (sentenceIndex, complete = false) => {
      const totalSeconds = wordsToSeconds(totalWords);
      const elapsedWords = complete
        ? totalWords
        : getWordOffsetForSentence(sentenceIndex);
      const elapsedSeconds = wordsToSeconds(elapsedWords);

      if (currentTimeEl) currentTimeEl.textContent = formatTime(elapsedSeconds);
      if (totalTimeEl) totalTimeEl.textContent = formatTime(totalSeconds);
    };

    const setPinnedState = (nextPinned) => {
      if (isPinned === nextPinned) return;
      isPinned = nextPinned;
      updatePinButton();
    };

    const updateFloatingState = () => {
      if (!shellEl) return;

      // Keep the control state in sync with player state:
      // idle at 0% => unpinned, playing/resumed => pinned.
      const progress = Number(seekEl?.value || "0");
      const isActivelyReading =
        getSupportsSpeech() &&
        speechSynthesis.speaking &&
        !speechSynthesis.paused &&
        !isUserPaused;
      const isStarting =
        getSupportsSpeech() &&
        speechSynthesis.pending &&
        !speechSynthesis.paused;

      // If playback is paused and user seeks back to 0, auto-unpin in auto mode.
      if (
        !hasManualPinOverride &&
        progress <= 0.1 &&
        !isActivelyReading &&
        !isStarting
      ) {
        setPinnedState(false);
      }

      if (!isPinned) {
        shellEl.classList.remove("is-floating");
        return;
      }
      const shouldFloat =
        hasManualPinOverride || progress > 0.1 || isActivelyReading;
      shellEl.classList.toggle("is-floating", shouldFloat);
    };

    const updatePinButton = () => {
      if (!btnPin) return;
      const actionLabel = isPinned ? "Unpin" : "Pin";
      btnPin.setAttribute("aria-pressed", isPinned ? "true" : "false");
      btnPin.setAttribute("aria-label", `${actionLabel} audio bar`);
      btnPin.setAttribute("title", actionLabel);
      btnPin.setAttribute("data-tooltip", actionLabel);
      if (pinLabelEl) pinLabelEl.textContent = actionLabel;
      iconPin?.classList.toggle("hidden", !isPinned);
      iconUnpin?.classList.toggle("hidden", isPinned);
      btnPin.classList.toggle("is-pinned", isPinned);
    };

    const updateMuteButton = () => {
      if (!btnMute) return;
      if (!getSupportsSpeech()) {
        btnMute.setAttribute("disabled", "true");
        btnMute.setAttribute("aria-label", "Mute unavailable");
        return;
      }
      btnMute.removeAttribute("disabled");
      btnMute.setAttribute("aria-pressed", isMuted ? "true" : "false");
      btnMute.setAttribute(
        "aria-label",
        isMuted ? "Unmute audio" : "Mute audio",
      );
      btnMute.classList.toggle("is-unmuted", !isMuted);
      iconVolume?.classList.toggle("hidden", isMuted);
      iconMuted?.classList.toggle("hidden", !isMuted);
    };

    const setSettingsOpen = (nextOpen) => {
      isSettingsOpen = Boolean(nextOpen);
      settingsPanelEl?.classList.toggle("is-open", isSettingsOpen);
      shellEl?.classList.toggle("is-settings-open", isSettingsOpen);
      btnSettings?.setAttribute(
        "aria-expanded",
        isSettingsOpen ? "true" : "false",
      );
      btnSettings?.setAttribute(
        "aria-label",
        isSettingsOpen ? "Close audio settings" : "Open audio settings",
      );
      btnSettings?.setAttribute(
        "title",
        isSettingsOpen ? "Close settings" : "Settings",
      );
      btnSettings?.classList.toggle("is-open", isSettingsOpen);
    };

    const resolveRoot = () => {
      if (root && document.contains(root)) return root;
      root = document.querySelector(target);
      return root;
    };

    const ensureHighlightLayer = () => {
      const readingRoot = resolveRoot();
      if (!readingRoot) return null;

      readingRoot.classList.add("ar-highlight-root");

      if (!highlightLayer || !readingRoot.contains(highlightLayer)) {
        highlightLayer = document.createElement("div");
        highlightLayer.className = "ar-highlight-layer";
        highlightLayer.setAttribute("aria-hidden", "true");
        readingRoot.prepend(highlightLayer);
      }

      return highlightLayer;
    };

    const clearSentenceHighlight = () => {
      if (highlightLayer) highlightLayer.replaceChildren();
    };

    const normalizeTextWithMap = (value) => {
      const source = String(value || "");
      let normalized = "";
      const map = [];
      let pendingSpace = false;

      for (let i = 0; i < source.length; i += 1) {
        const char = source[i];
        if (/\s/.test(char)) {
          pendingSpace = normalized.length > 0;
          continue;
        }

        if (pendingSpace) {
          normalized += " ";
          map.push(i);
          pendingSpace = false;
        }

        normalized += char;
        map.push(i);
      }

      return { text: normalized, map };
    };

    const findTextPosition = (textNodes, rawOffset, preferEnd = false) => {
      let traversed = 0;

      for (let i = 0; i < textNodes.length; i += 1) {
        const textNode = textNodes[i];
        const length = textNode.nodeValue?.length ?? 0;
        const next = traversed + length;

        if (rawOffset < next) {
          return { node: textNode, offset: Math.max(0, rawOffset - traversed) };
        }

        if (rawOffset === next) {
          if (preferEnd && i + 1 < textNodes.length) {
            return { node: textNodes[i + 1], offset: 0 };
          }
          return { node: textNode, offset: length };
        }

        traversed = next;
      }

      const last = textNodes[textNodes.length - 1];
      if (!last) return null;
      return { node: last, offset: last.nodeValue?.length ?? 0 };
    };

    const buildSentenceRange = (entry) => {
      if (!entry?.rangeStart || !entry?.rangeEnd) return null;
      if (
        !document.contains(entry.rangeStart.node) ||
        !document.contains(entry.rangeEnd.node)
      ) {
        return null;
      }

      try {
        const range = document.createRange();
        range.setStart(entry.rangeStart.node, entry.rangeStart.offset);
        range.setEnd(entry.rangeEnd.node, entry.rangeEnd.offset);
        if (range.collapsed) return null;
        return range;
      } catch {
        return null;
      }
    };

    const renderSentenceHighlight = (entry) => {
      const readingRoot = resolveRoot();
      const layer = ensureHighlightLayer();
      if (!readingRoot || !layer) return null;

      layer.replaceChildren();
      const range = buildSentenceRange(entry);
      if (!range) return null;

      const rootRect = readingRoot.getBoundingClientRect();
      const rects = Array.from(range.getClientRects()).filter(
        (rect) => rect.width > 0.5 && rect.height > 0.5,
      );

      rects.forEach((rect) => {
        const chip = document.createElement("span");
        chip.className = "ar-highlight-chip";
        chip.style.left = `${rect.left - rootRect.left + readingRoot.scrollLeft}px`;
        chip.style.top = `${rect.top - rootRect.top + readingRoot.scrollTop}px`;
        chip.style.width = `${rect.width}px`;
        chip.style.height = `${rect.height}px`;
        layer.appendChild(chip);
      });

      return range;
    };

    const refreshActiveSentenceHighlight = () => {
      if (currentSentenceIndex < 0) return;
      const entry = sentences[currentSentenceIndex];
      if (!entry) return;
      renderSentenceHighlight(entry);
    };

    const splitSentences = (text) => {
      const cleaned = (text || "").replace(/\s+/g, " ").trim();
      if (!cleaned) return [];
      const parts = cleaned.match(/[^.!?]+[.!?]+|[^.!?]+$/g) || [cleaned];
      return parts.map((s) => s.trim()).filter(Boolean);
    };

    const countWords = (text) => {
      const cleaned = String(text || "").trim();
      if (!cleaned) return 0;
      return cleaned.split(/\s+/).filter(Boolean).length;
    };

    const normalizeVoiceToken = (value) =>
      String(value || "")
        .toLowerCase()
        .replace(/[_-]+/g, " ")
        .replace(/\s+/g, " ")
        .trim();

    const isGoogleUsEnUs = (voice) => {
      const name = normalizeVoiceToken(voice?.name);
      const lang = normalizeVoiceToken(voice?.lang);
      return (
        name.includes("google") &&
        name.includes("us") &&
        (lang === "en us" || lang.startsWith("en us") || name.includes("en us"))
      );
    };

    const isGoogleUkFemale = (voice) => {
      const name = normalizeVoiceToken(voice?.name);
      return (
        name.includes("google") &&
        name.includes("uk") &&
        name.includes("female")
      );
    };

    const isEnglishVoice = (voice) => {
      const lang = normalizeVoiceToken(voice?.lang);
      return lang === "en" || lang.startsWith("en ");
    };

    const getVoicePool = () => {
      if (!getSupportsSpeech()) return [];
      const availableVoices = speechSynthesis.getVoices() || [];
      const englishVoices = availableVoices.filter(isEnglishVoice);
      return englishVoices.length ? englishVoices : availableVoices;
    };

    const resolvePreferredVoice = (requestedName) => {
      if (!voices.length) return null;

      if (requestedName) {
        const requested = voices.find((voice) => voice.name === requestedName);
        if (requested) return requested;
      }

      return (
        voices.find(isGoogleUsEnUs) ||
        voices.find(isGoogleUkFemale) ||
        voices.find((voice) => voice.default) ||
        voices[0]
      );
    };

    const updateSeekUi = (
      sentenceIndex,
      updateSlider = true,
      complete = false,
    ) => {
      const percent =
        sentences.length <= 1
          ? 0
          : (Math.max(0, Math.min(sentences.length - 1, sentenceIndex)) /
              (sentences.length - 1)) *
            100;

      if (seekEl && updateSlider) seekEl.value = percent.toFixed(1);
      if (seekEl) {
        seekEl.style.setProperty("--ar-fill", `${percent.toFixed(2)}%`);
      }

      updateTimeUiForSentence(sentenceIndex, complete);
      updateFloatingState();
    };

    const sentenceIndexFromProgress = (percent) => {
      if (!sentences.length) return 0;
      const clamped = Math.max(0, Math.min(100, percent));
      return Math.round((clamped / 100) * (sentences.length - 1));
    };

    const clearActiveSentence = () => {
      clearSentenceHighlight();
      currentSentenceIndex = -1;
    };

    const setActiveSentence = (index, scroll = true) => {
      if (index === currentSentenceIndex) {
        const currentEntry = sentences[index];
        if (currentEntry) renderSentenceHighlight(currentEntry);
        return;
      }
      clearActiveSentence();

      const entry = sentences[index];
      if (!entry) return;

      currentSentenceIndex = index;
      const range = renderSentenceHighlight(entry);

      if (scroll) {
        let shouldScroll = true;
        if (range) {
          const rect = range.getBoundingClientRect();
          const margin = Math.max(96, window.innerHeight * 0.18);
          shouldScroll =
            rect.top < margin || rect.bottom > window.innerHeight - margin;
        }
        if (shouldScroll && entry.anchor instanceof Element) {
          entry.anchor.scrollIntoView({
            behavior: "smooth",
            block: "center",
            inline: "nearest",
          });
        }
      }
    };

    const updateToggleButton = () => {
      if (!btnToggle || !btnToggleLabel) return;
      if (!getSupportsSpeech()) {
        btnToggle.setAttribute("disabled", "true");
        btnToggle.setAttribute("aria-label", "Text to speech unavailable");
        setStatus("Text to speech is unavailable in this browser.");
        updateFloatingState();
        return;
      }

      if (isUserPaused || speechSynthesis.paused) {
        btnToggleLabel.textContent = "Play";
        btnToggle.setAttribute("aria-label", "Play audio");
        btnToggle.setAttribute("aria-pressed", "false");
        btnToggle.classList.remove("is-playing");
        iconPlay?.classList.remove("hidden");
        iconPause?.classList.add("hidden");
        setStatus("Paused");
        updateFloatingState();
        return;
      }

      if (speechSynthesis.speaking) {
        btnToggleLabel.textContent = "Pause";
        btnToggle.setAttribute("aria-label", "Pause audio");
        btnToggle.setAttribute("aria-pressed", "true");
        btnToggle.classList.add("is-playing");
        iconPlay?.classList.add("hidden");
        iconPause?.classList.remove("hidden");
        setStatus("Reading...");
        updateFloatingState();
        return;
      }

      btnToggleLabel.textContent = "Play";
      btnToggle.setAttribute("aria-label", "Play audio");
      btnToggle.setAttribute("aria-pressed", "false");
      btnToggle.classList.remove("is-playing");
      iconPlay?.classList.remove("hidden");
      iconPause?.classList.add("hidden");
      setStatus("Ready");
      updateFloatingState();
    };

    const cancelSpeech = () => {
      sessionId += 1;
      if (
        getSupportsSpeech() &&
        (speechSynthesis.speaking ||
          speechSynthesis.pending ||
          speechSynthesis.paused)
      ) {
        speechSynthesis.cancel();
      }
      activeUtterance = null;
      updateToggleButton();
    };

    const prepare = () => {
      const readingRoot = resolveRoot();
      if (!readingRoot) return false;

      if (prepared) return sentences.length > 0;

      ensureHighlightLayer();
      clearSentenceHighlight();

      const selectors = "p, li, h1, h2, h3, h4, blockquote";
      const nodes = readingRoot.querySelectorAll(selectors);

      sentences = [];

      nodes.forEach((node) => {
        const walker = document.createTreeWalker(node, NodeFilter.SHOW_TEXT);
        const textNodes = [];
        let textNode = walker.nextNode();
        while (textNode) {
          if (textNode.nodeValue) textNodes.push(textNode);
          textNode = walker.nextNode();
        }
        if (!textNodes.length) return;

        const rawText = textNodes.map((entry) => entry.nodeValue || "").join("");
        const normalized = normalizeTextWithMap(rawText);
        if (!normalized.text) return;

        const parts = splitSentences(normalized.text);
        if (!parts.length) return;

        let cursor = 0;
        parts.forEach((sentence) => {
          const startIndex = normalized.text.indexOf(sentence, cursor);
          if (startIndex < 0) return;

          const endIndex = startIndex + sentence.length;
          cursor = endIndex;
          while (
            cursor < normalized.text.length &&
            normalized.text[cursor] === " "
          ) {
            cursor += 1;
          }

          const rawStart = normalized.map[startIndex];
          const rawEnd = normalized.map[endIndex - 1] + 1;
          if (!Number.isFinite(rawStart) || !Number.isFinite(rawEnd)) return;
          const rangeStart = findTextPosition(textNodes, rawStart, false);
          const rangeEnd = findTextPosition(textNodes, rawEnd, true);

          sentences.push({
            text: sentence,
            words: countWords(sentence),
            anchor: node,
            rangeStart,
            rangeEnd,
          });
        });
      });

      if (!sentences.length) {
        splitSentences(readingRoot.textContent || "").forEach((sentence) => {
          sentences.push({
            text: sentence,
            words: countWords(sentence),
            anchor: readingRoot,
            rangeStart: null,
            rangeEnd: null,
          });
        });
      }

      sentenceWordOffsets = [];
      totalWords = 0;
      sentences.forEach((entry, index) => {
        sentenceWordOffsets[index] = totalWords;
        totalWords += entry.words;
      });

      prepared = true;
      playheadSentenceIndex = 0;
      hasCompleted = false;
      isUserPaused = false;
      updateSeekUi(playheadSentenceIndex, true, false);

      return sentences.length > 0;
    };

    const speakSentenceFrom = (startIndex) => {
      if (!getSupportsSpeech()) return;

      const idx = Math.max(0, Math.min(sentences.length - 1, startIndex));
      if (!sentences[idx]) {
        hasCompleted = true;
        isUserPaused = false;
        updateSeekUi(Math.max(0, sentences.length - 1), true, true);
        updateToggleButton();
        return;
      }

      sessionId += 1;
      const currentSession = sessionId;

      const utterance = new SpeechSynthesisUtterance(sentences[idx].text);
      utterance.rate = getRateValue();
      utterance.volume = isMuted ? 0 : 1;
      utterance.pitch = 1;

      if (!voices.length) {
        voices = getVoicePool();
      }

      const selected = resolvePreferredVoice(voiceEl?.value);
      if (selected) {
        utterance.voice = selected;
        utterance.lang = selected.lang || "en-US";
        if (voiceEl) voiceEl.value = selected.name;
      } else {
        utterance.lang = document.documentElement.lang || "en-US";
      }

      activeUtterance = utterance;

      let didStart = false;

      utterance.onstart = () => {
        if (currentSession !== sessionId) return;
        didStart = true;
        playheadSentenceIndex = idx;
        hasCompleted = false;
        isUserPaused = false;
        setActiveSentence(idx);
        updateSeekUi(idx, true, false);
        setStatus("Reading...");
        updateToggleButton();
      };

      utterance.onend = () => {
        if (currentSession !== sessionId) return;

        const nextIndex = idx + 1;
        if (nextIndex >= sentences.length) {
          clearActiveSentence();
          playheadSentenceIndex = Math.max(0, sentences.length - 1);
          hasCompleted = true;
          isUserPaused = false;
          updateSeekUi(playheadSentenceIndex, true, true);
          activeUtterance = null;
          setStatus("Completed");
          updateToggleButton();
          return;
        }

        playheadSentenceIndex = nextIndex;
        speakSentenceFrom(nextIndex);
      };

      utterance.onerror = () => {
        if (currentSession !== sessionId) return;
        clearActiveSentence();
        activeUtterance = null;
        isUserPaused = false;
        setStatus("Could not play audio. Try another voice.");
        updateToggleButton();
      };

      speechSynthesis.speak(utterance);
      window.setTimeout(() => {
        if (didStart || currentSession !== sessionId) return;
        if (!getSupportsSpeech()) return;
        speechSynthesis.cancel();
        speechSynthesis.speak(utterance);
      }, 900);
      updateToggleButton();
    };

    const play = (fromIndex = playheadSentenceIndex) => {
      if (!getSupportsSpeech()) {
        alert("Text-to-speech is not supported in this browser.");
        setStatus("Text to speech is unavailable in this browser.");
        return;
      }

      if (!prepare()) {
        alert("No readable content found for audio playback.");
        setStatus("No readable content found.");
        return;
      }

      if (isUserPaused) {
        hasManualPinOverride = false;
        setPinnedState(true);
        isUserPaused = false;
        setStatus("Starting...");
        speakSentenceFrom(playheadSentenceIndex);
        return;
      }

      if (speechSynthesis.paused) {
        hasManualPinOverride = false;
        setPinnedState(true);
        isUserPaused = false;
        speechSynthesis.resume();
        updateToggleButton();
        return;
      }

      if (speechSynthesis.speaking) return;

      const start = hasCompleted ? 0 : fromIndex;
      hasManualPinOverride = false;
      setPinnedState(true);
      setStatus("Starting...");
      speakSentenceFrom(start);
    };

    const pause = () => {
      if (!getSupportsSpeech()) return;
      if (
        speechSynthesis.speaking ||
        speechSynthesis.pending ||
        speechSynthesis.paused
      ) {
        isUserPaused = true;
        cancelSpeech();
        setStatus("Paused");
      }
    };

    const seekToProgress = (percent) => {
      if (!prepare()) return;

      const nextIndex = sentenceIndexFromProgress(percent);
      playheadSentenceIndex = nextIndex;
      hasCompleted = false;
      updateSeekUi(nextIndex, true, false);
      setActiveSentence(nextIndex, false);

      if (!getSupportsSpeech()) return;

      const wasPaused = isUserPaused || speechSynthesis.paused;
      const wasActive =
        speechSynthesis.speaking || speechSynthesis.paused || isUserPaused;

      if (!wasActive) return;

      cancelSpeech();
      if (wasPaused) {
        isUserPaused = true;
        setStatus("Paused");
        updateToggleButton();
        return;
      }

      speakSentenceFrom(nextIndex);
    };

    const loadVoices = () => {
      if (!getSupportsSpeech()) return;

      const currentSelection = voiceEl?.value || "";
      voices = getVoicePool();
      if (!voiceEl) return;

      voiceEl.innerHTML = "";
      voices.forEach((voice) => {
        const option = document.createElement("option");
        option.value = voice.name;
        option.textContent = `${voice.name} (${voice.lang})`;
        option.style.color = "#0f172a";
        option.style.backgroundColor = "#ffffff";
        voiceEl.appendChild(option);
      });

      const preferred = resolvePreferredVoice(currentSelection);
      if (preferred) voiceEl.value = preferred.name;
    };

    btnToggle?.addEventListener("click", () => {
      if (!getSupportsSpeech()) return;

      if (isUserPaused || speechSynthesis.paused) {
        hasManualPinOverride = false;
        setPinnedState(true);
        isUserPaused = false;
        speechSynthesis.resume();
        updateToggleButton();
        return;
      }

      if (speechSynthesis.speaking) {
        pause();
        return;
      }

      play();
    });

    btnPin?.addEventListener("click", () => {
      hasManualPinOverride = true;
      setPinnedState(!isPinned);
      updateFloatingState();
    });

    btnSettings?.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      setSettingsOpen(!isSettingsOpen);
    });

    settingsPanelEl?.addEventListener("click", (event) => {
      event.stopPropagation();
    });

    document.addEventListener("click", (event) => {
      const targetNode = event.target;
      if (!(targetNode instanceof Node)) return;
      if (
        btnSettings?.contains(targetNode) ||
        settingsPanelEl?.contains(targetNode)
      )
        return;
      setSettingsOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setSettingsOpen(false);
      }
    });

    btnMute?.addEventListener("click", () => {
      isMuted = !isMuted;
      updateMuteButton();

      if (!getSupportsSpeech()) return;
      const wasPaused = isUserPaused || speechSynthesis.paused;
      const wasActive =
        speechSynthesis.speaking || speechSynthesis.paused || isUserPaused;
      if (!wasActive) return;

      cancelSpeech();
      speakSentenceFrom(playheadSentenceIndex);
      if (wasPaused) {
        isUserPaused = true;
        speechSynthesis.pause();
        updateToggleButton();
      }
    });

    rateEl?.addEventListener("change", () => {
      updateTimeUiForSentence(playheadSentenceIndex, hasCompleted);
      if (!getSupportsSpeech()) return;
      if (speechSynthesis.speaking || speechSynthesis.paused || isUserPaused) {
        const wasPaused = isUserPaused || speechSynthesis.paused;
        cancelSpeech();
        speakSentenceFrom(playheadSentenceIndex);
        if (wasPaused) {
          isUserPaused = true;
          speechSynthesis.pause();
          updateToggleButton();
        }
      }
    });

    voiceEl?.addEventListener("change", () => {
      if (!getSupportsSpeech()) return;
      if (speechSynthesis.speaking || speechSynthesis.paused || isUserPaused) {
        const wasPaused = isUserPaused || speechSynthesis.paused;
        cancelSpeech();
        speakSentenceFrom(playheadSentenceIndex);
        if (wasPaused) {
          isUserPaused = true;
          speechSynthesis.pause();
          updateToggleButton();
        }
      }
    });

    seekEl?.addEventListener("input", () => {
      if (!prepare()) return;
      const preview = sentenceIndexFromProgress(Number(seekEl.value || "0"));
      updateSeekUi(preview, false, false);
    });

    seekEl?.addEventListener("change", () => {
      seekToProgress(Number(seekEl?.value || "0"));
    });

    window.addEventListener("resize", refreshActiveSentenceHighlight);
    window.addEventListener("orientationchange", refreshActiveSentenceHighlight);

    if (getSupportsSpeech()) {
      loadVoices();
      speechSynthesis.onvoiceschanged = loadVoices;
    }

    const precomputeDurationOnLoad = () => {
      if (prepared) return;
      if (!prepare()) return;
      updateSeekUi(playheadSentenceIndex, true, false);
      updateToggleButton();
      updateFloatingState();
    };

    if (document.readyState === "loading") {
      document.addEventListener(
        "DOMContentLoaded",
        () => {
          window.setTimeout(precomputeDurationOnLoad, 0);
        },
        { once: true },
      );
    } else {
      window.setTimeout(precomputeDurationOnLoad, 0);
    }

    updateSeekUi(0, true, false);
    updateMuteButton();
    setSettingsOpen(false);
    updatePinButton();
    updateToggleButton();
    updateFloatingState();
  })();
</script>
