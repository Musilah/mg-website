---
const { target = "#post" } = Astro.props;
---

<div
  id="ar-shell"
  class="audio-reader-shell z-40 my-6 rounded-2xl border border-subtle px-4 py-3 shadow-[var(--shadow-soft)]"
>
  <div class="audio-player">
    <div class="audio-left">
      <button
        id="ar-toggle"
        class="audio-glass-control audio-toggle inline-flex h-12 w-12 items-center justify-center rounded-full transition hover:-translate-y-0.5"
        aria-pressed="false"
        aria-label="Play audio"
      >
        <svg
          id="ar-icon-play"
          class="h-8 w-8"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M8 6.5v11L17.5 12 8 6.5z"></path>
        </svg>
        <svg
          id="ar-icon-pause"
          class="hidden h-8 w-8"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <rect x="7" y="5.5" width="3.2" height="13" rx="1"></rect>
          <rect x="13.8" y="5.5" width="3.2" height="13" rx="1"></rect>
        </svg>
        <span id="ar-toggle-label" class="sr-only">Play</span>
      </button>

      <button
        id="ar-mute"
        class="audio-glass-control audio-mute inline-flex h-10 w-10 items-center justify-center rounded-full transition hover:-translate-y-0.5"
        aria-pressed="false"
        aria-label="Mute audio"
      >
        <svg
          id="ar-icon-volume"
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polygon points="11 5 6 9 3 9 3 15 6 15 11 19 11 5"></polygon>
          <path d="M15.5 8.5a5 5 0 0 1 0 7"></path>
          <path d="M18.5 6a9 9 0 0 1 0 12"></path>
        </svg>
        <svg
          id="ar-icon-muted"
          class="hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polygon points="11 5 6 9 3 9 3 15 6 15 11 19 11 5"></polygon>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
        <span class="sr-only">Mute</span>
      </button>

      <span class="audio-time">
        <span id="ar-current-time">00:00</span>
        <span aria-hidden="true"> / </span>
        <span id="ar-total-time">00:00</span>
      </span>
    </div>

    <div class="audio-main">
      <label class="sr-only" for="ar-seek">Reader progress</label>
      <input
        id="ar-seek"
        type="range"
        min="0"
        max="100"
        step="0.1"
        value="0"
        class="audio-glass-range w-full accent-[var(--accent)]"
        aria-label="Reader progress"
      />
    </div>

