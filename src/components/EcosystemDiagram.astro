---
const products = [
  {
    name: "FluxMQ",
    label: "Messaging",
    description: "Durable event transport",
    href: "https://fluxmq.absmach.eu",
    accent: "fluxmq",
    area: "fluxmq",
    icon: `<svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.5 3h10M1.5 6.5h7.5M1.5 10h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  },
  {
    name: "Propeller",
    label: "Orchestration",
    description: "WebAssembly across cloud and edge",
    href: "https://propeller.absmach.eu",
    accent: "propeller",
    area: "propeller",
    icon: `<svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 4L1.5 6.5L3 9M10 4L11.5 6.5L10 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.5 2v9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  },
  {
    name: "Magistrala",
    label: "Flagship platform",
    description: "Identity, access, MQTT and device management",
    href: "https://magistrala.absmach.eu",
    accent: "magistrala",
    area: "magistrala",
    featured: true,
    icon: `<svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="6.5" cy="6.5" r="2" fill="currentColor"/><circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.2" stroke-dasharray="2.5 2"/></svg>`,
  },
  {
    name: "S0 Gateway",
    label: "Low-power hardware",
    description: "RISC-V edge node for lightweight deployments",
    href: "https://hardware.absmach.eu",
    accent: "s0",
    area: "s0",
    icon: `<svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2.5" y="2.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><rect x="4.75" y="4.75" width="3.5" height="3.5" rx="0.5" fill="currentColor" opacity="0.75"/></svg>`,
  },
  {
    name: "S1 Gateway",
    label: "Industrial hardware",
    description: "RISC-V edge system for demanding environments",
    href: "https://hardware.absmach.eu",
    accent: "s1",
    area: "s1",
    icon: `<svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2.5" y="3.5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><rect x="4.75" y="5.75" width="3.5" height="3.5" rx="0.5" fill="currentColor" opacity="0.75"/><path d="M6.5 1v2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>`,
  },
];
---

<div class="eco-wrap">
  <!-- SVG overlay: connector lines + animated dots, drawn by JS -->
  <svg
    class="eco-connectors"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  ></svg>

  <div class="ecosystem-grid" aria-label="Product ecosystem">
    {products.map((product) => (
      <a
        href={product.href}
        target="_blank"
        rel="noopener noreferrer"
        data-area={product.area}
        class={`eco-card eco-card--${product.accent}${product.featured ? " eco-card--featured" : ""}`}
        style={`grid-area:${product.area}`}
        aria-label={`${product.name}: ${product.description}`}
      >
        <span class="eco-card-icon" aria-hidden="true" set:html={product.icon}></span>
        <span class="eco-label">{product.label}</span>
        <span class="eco-name">{product.name}</span>
        <span class="eco-desc">{product.description}</span>
        <span class="eco-arrow" aria-hidden="true">↗</span>
      </a>
    ))}
  </div>
</div>

<style>
  /* ── Wrapper ───────────────────────────────────────────── */
  .eco-wrap {
    position: relative;
  }

  /* ── SVG connector overlay ─────────────────────────────── */
  .eco-connectors {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    z-index: 0;
  }

  /* ── Grid ──────────────────────────────────────────────── */
  .ecosystem-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    grid-template-areas:
      "fluxmq    fluxmq    fluxmq    propeller propeller propeller"
      ".         magistrala magistrala magistrala magistrala ."
      "s0        s0        s0        s1        s1        s1";
    position: relative;
    z-index: 1;
  }

  /* ── Cards ─────────────────────────────────────────────── */
  .eco-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-height: 8rem;
    padding: 1rem 1.1rem 1rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--card-accent) 22%, var(--border));
    background: var(--panel);
    color: var(--text);
    text-decoration: none;
    box-shadow: var(--shadow-soft);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease;
    overflow: hidden;
  }

  /* Very faint accent tint at the top of each card */
  .eco-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--card-accent) 6%, transparent) 0%,
      transparent 55%
    );
    pointer-events: none;
  }

  .eco-card:hover,
  .eco-card:focus-visible {
    border-color: color-mix(in srgb, var(--card-accent) 55%, var(--border));
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.12),
      0 2px 6px rgba(0, 0, 0, 0.06);
  }

  .eco-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--card-accent) 50%, transparent);
    outline-offset: 2px;
  }

  .eco-card--featured {
    min-height: 9.5rem;
    padding: 1.15rem 1.25rem 1.15rem;
  }

  /* Accent left bar on featured card */
  .eco-card--featured::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: 12px 0 0 12px;
    background: var(--card-accent);
  }

  /* ── Card icon (top-right corner) ──────────────────────── */
  .eco-card-icon {
    position: absolute;
    top: 0.85rem;
    right: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--card-accent);
    opacity: 0.38;
    pointer-events: none;
  }

  /* ── Type ──────────────────────────────────────────────── */
  .eco-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--card-accent) 70%, var(--muted));
    font-family: "JetBrains Mono", "Courier New", monospace;
    line-height: 1;
  }

  .eco-name {
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--text);
    margin-top: 0.1rem;
  }

  .eco-card--featured .eco-name {
    font-size: clamp(1.05rem, 1.5vw, 1.45rem);
  }

  .eco-desc {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .eco-arrow {
    margin-top: auto;
    padding-top: 0.3rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--card-accent);
    opacity: 0.8;
  }

  /* ── Per-product accent colours ────────────────────────── */
  .eco-card--magistrala { --card-accent: #4c83ff; }
  .eco-card--fluxmq     { --card-accent: #f4a62a; }
  .eco-card--propeller  { --card-accent: #c0293d; }
  .eco-card--s0         { --card-accent: #e06060; }
  .eco-card--s1         { --card-accent: #8090b8; }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .ecosystem-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-areas:
        "magistrala magistrala"
        "fluxmq    propeller"
        "s0        s1";
      gap: 0.625rem;
    }

    .eco-card--featured {
      min-height: 8.5rem;
    }
  }

  @media (max-width: 479px) {
    .ecosystem-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "magistrala"
        "fluxmq"
        "propeller"
        "s0"
        "s1";
    }

    .eco-card {
      min-height: 6rem;
    }
  }
</style>

<script>
  function drawEcoConnectors(): void {
    const wrap = document.querySelector<HTMLElement>(".eco-wrap");
    const svg = document.querySelector<SVGSVGElement>(".eco-connectors");
    const grid = document.querySelector<HTMLElement>(".ecosystem-grid");
    if (!wrap || !svg || !grid) return;

    const wr = wrap.getBoundingClientRect();
    if (wr.width === 0) return;

    const ns = "http://www.w3.org/2000/svg";

    const pos = (area: string) => {
      const el = grid.querySelector<HTMLElement>(`[data-area="${area}"]`);
      if (!el) return null;
      const r = el.getBoundingClientRect();
      return {
        t: r.top - wr.top,
        b: r.bottom - wr.top,
        l: r.left - wr.left,
        r: r.right - wr.left,
        cx: r.left - wr.left + r.width / 2,
        w: r.width,
        h: r.height,
      };
    };

    const mag = pos("magistrala");
    const flx = pos("fluxmq");
    const prp = pos("propeller");
    const s0p = pos("s0");
    const s1p = pos("s1");
    if (!mag || !flx || !prp || !s0p || !s1p) return;

    svg.setAttribute("viewBox", `0 0 ${wr.width} ${wr.height}`);
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    // All connections converge on Magistrala (the hub)
    const connections = [
      {
        id: "eco-c-fluxmq",
        // FluxMQ bottom-center → Magistrala top (left quadrant)
        d: cubicV(flx.cx, flx.b, mag.l + mag.w * 0.28, mag.t),
        color: "#f4a62a",
        dur: "2.6s",
        delay: "0s",
      },
      {
        id: "eco-c-propeller",
        // Propeller bottom-center → Magistrala top (right quadrant)
        d: cubicV(prp.cx, prp.b, mag.l + mag.w * 0.72, mag.t),
        color: "#c0293d",
        dur: "2.6s",
        delay: "1.3s",
      },
      {
        id: "eco-c-s0",
        // S0 top-center → Magistrala bottom (left quadrant)
        d: cubicV(s0p.cx, s0p.t, mag.l + mag.w * 0.28, mag.b),
        color: "#e06060",
        dur: "2.6s",
        delay: "0.65s",
      },
      {
        id: "eco-c-s1",
        // S1 top-center → Magistrala bottom (right quadrant)
        d: cubicV(s1p.cx, s1p.t, mag.l + mag.w * 0.72, mag.b),
        color: "#8090b8",
        dur: "2.6s",
        delay: "1.95s",
      },
    ];

    connections.forEach(({ id, d, color, dur, delay }) => {
      // Static connector line
      const line = document.createElementNS(ns, "path");
      line.setAttribute("id", id);
      line.setAttribute("d", d);
      line.setAttribute("stroke", color);
      line.setAttribute("stroke-width", "1.5");
      line.setAttribute("fill", "none");
      line.setAttribute("opacity", "0.22");
      svg.appendChild(line);

      if (reducedMotion) return;

      // Animated dot that travels along the line
      const dot = document.createElementNS(ns, "circle");
      dot.setAttribute("r", "2.5");
      dot.setAttribute("fill", color);
      dot.setAttribute("opacity", "0.78");

      const motion = document.createElementNS(ns, "animateMotion");
      motion.setAttribute("dur", dur);
      motion.setAttribute("repeatCount", "indefinite");
      motion.setAttribute("begin", delay);
      motion.setAttribute("calcMode", "linear");

      const mpath = document.createElementNS(ns, "mpath");
      mpath.setAttribute("href", `#${id}`);

      motion.appendChild(mpath);
      dot.appendChild(motion);
      svg.appendChild(dot);
    });
  }

  /** Cubic bezier with vertical tangents — clean S-curve between two points */
  function cubicV(x1: number, y1: number, x2: number, y2: number): string {
    const my = (y1 + y2) / 2;
    return `M ${x1} ${y1} C ${x1} ${my}, ${x2} ${my}, ${x2} ${y2}`;
  }

  // Draw after layout is complete
  requestAnimationFrame(drawEcoConnectors);

  // Redraw on resize
  const wrapEl = document.querySelector(".eco-wrap");
  if (wrapEl) {
    new ResizeObserver(() => drawEcoConnectors()).observe(wrapEl);
  }
</script>
