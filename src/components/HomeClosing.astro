---
const intents = [
  {
    type: "Deploy",
    heading: "Production deployments",
    body: "Need IoT infrastructure, secure edge connectivity, or a managed deployment? We work through the technical detail with you.",
    cta: { label: "Get in touch", href: "/contact/", external: false },
    primary: true,
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="2" y="2" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.35"/><rect x="10" y="2" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.35"/><rect x="2" y="10" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.35"/><path d="M13 10v6M10 13h6" stroke="currentColor" stroke-width="1.35" stroke-linecap="round"/></svg>`,
  },
  {
    type: "Research",
    heading: "Academic & EU collaboration",
    body: "Working on a Horizon Europe project, a research consortium or an academic partnership? We're looking for the right collaborators.",
    cta: { label: "Start a conversation", href: "/contact/", external: false },
    primary: false,
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.35"/><path d="M9 5.5v4l2.5 2.5" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    type: "Open Source",
    heading: "github.com/absmach",
    body: "All core products are open source. Browse the repositories, open an issue or contribute a pull request.",
    cta: { label: "View on GitHub ↗", href: "https://github.com/absmach", external: true },
    primary: false,
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 1.5C4.86 1.5 1.5 4.86 1.5 9c0 3.315 2.151 6.127 5.134 7.118.375.069.512-.163.512-.362 0-.179-.007-.773-.01-1.399C5.25 14.91 4.8 13.5 4.8 13.5c-.338-.858-.825-1.087-.825-1.087-.675-.461.051-.452.051-.452.746.052 1.138.767 1.138.767.663 1.135 1.738.807 2.162.617.067-.48.259-.807.471-.992C6 12.138 4.313 11.516 4.313 8.834c0-.771.276-1.402.727-1.896-.073-.178-.315-.897.069-1.869 0 0 .592-.19 1.94.723A6.76 6.76 0 019 5.442c.6.003 1.203.081 1.767.238 1.347-.913 1.938-.723 1.938-.723.385.972.143 1.691.07 1.869.453.494.726 1.125.726 1.896 0 2.69-1.69 3.282-3.3 3.455.26.224.491.665.491 1.34 0 .967-.009 1.748-.009 1.985 0 .2.135.434.516.361C15.352 15.124 16.5 12.314 16.5 9c0-4.14-3.36-7.5-7.5-7.5Z" fill="currentColor" opacity=".8"/></svg>`,
  },
];
---

<section class="hc-section" aria-label="Work with Abstract Machines">
  <div class="container-wide">
    <div class="hc-grid">
      {intents.map((intent, i) => (
        <div class={`hc-block${i < intents.length - 1 ? " hc-block--divided" : ""}`}>
          <div class="hc-icon" set:html={intent.icon} />
          <p class="hc-type">{intent.type}</p>
          <h3 class="hc-heading">{intent.heading}</h3>
          <p class="hc-body">{intent.body}</p>
          <a
            href={intent.cta.href}
            target={intent.cta.external ? "_blank" : undefined}
            rel={intent.cta.external ? "noopener noreferrer" : undefined}
            class={intent.primary ? "button-primary" : "button-secondary"}
          >
            {intent.cta.label}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hc-section {
    padding: clamp(3rem, 5vw, 5rem) 0;
  }

  .hc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .hc-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }

    .hc-block--divided {
      border-right: 1px solid var(--border);
      padding-right: clamp(1.5rem, 3vw, 2.75rem);
      margin-right: 0;
    }

    .hc-block:not(:first-child) {
      padding-left: clamp(1.5rem, 3vw, 2.75rem);
    }
  }

  @media (max-width: 767px) {
    .hc-block--divided {
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
    }
  }

  .hc-icon {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    color: var(--accent);
    opacity: 0.65;
    margin-bottom: 1rem;
  }

  .hc-type {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .hc-heading {
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 0.65rem;
  }

  .hc-body {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    max-width: 40ch;
  }
</style>
