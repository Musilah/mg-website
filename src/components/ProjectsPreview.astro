---
import { Image } from "astro:assets";

const featuredProject = {
  name: "ELASTIC",
  tagline: "Portable, Secure Service Orchestration for 6G",
  description:
    "WebAssembly-based workload orchestration with Trusted Execution Environments and eBPF/XDP for secure, portable service delivery across the 6G cloud-to-edge continuum. Abstract Machines leads FaaS orchestration and TEE workload management.",
  duration: "2024–2027",
  program: "EU Horizon Europe",
  role: "Task Lead, WP2 & WP4",
  areas: ["WebAssembly", "FaaS Orchestration", "Trusted Execution", "6G Edge"],
  href: "/projects/elastic/",
  logoSrc: "/img/logos/elastic.png",
  logoAlt: "ELASTIC project logo",
  logoClass: "invert dark:invert-0",
  external: false,
  accent: "#34c38f",
};

const secondaryProjects = [
  {
    name: "CONFIDENTIAL6G",
    tagline: "Post-Quantum Security for 6G Networks",
    description:
      "Post-quantum cryptographic libraries and confidential computing frameworks for the 6G cloud-edge continuum. Abstract Machines served as Technical Manager.",
    duration: "2023–2025",
    program: "EU Horizon Europe",
    status: "Completed",
    areas: ["Post-Quantum", "Confidential Computing", "6G Security"],
    href: "/projects/confidential6g/",
    logoSrc: "/img/logos/confidential6G.jpg",
    logoAlt: "CONFIDENTIAL6G project logo",
    external: false,
    accent: "#4c83ff",
  },
  {
    name: "EdgeX Foundry",
    tagline: "Open Source Edge Platform",
    description:
      "Contributing to the Linux Foundation's EdgeX Foundry project. Magistrala integration bridges edge intelligence with cloud-scale connectivity.",
    duration: "2017–Present",
    program: "Linux Foundation",
    areas: ["Edge Computing", "IoT", "Open Source", "Interoperability"],
    href: "https://www.edgexfoundry.org",
    logoSrc: "/img/logos/lf.png",
    logoAlt: "Linux Foundation logo",
    external: true,
    accent: "#8090b8",
  },
];
---

<section
  id="projects-preview"
  class="scroll-mt-16"
  style="padding-top: clamp(2.5rem, 4vw, 4rem); padding-bottom: clamp(2.5rem, 4vw, 4rem);"
>
  <div class="container-wide">

    <div class="proj-head">
      <div>
        <p class="section-label">Research &amp; Collaborations</p>
        <h2 class="section-title mt-0.5">Projects</h2>
      </div>
      <a class="button-secondary proj-view-all" href="/projects/">View all →</a>
    </div>

    <!-- ── Featured project: CONFIDENTIAL6G ─────────────── -->
    <article class="proj-featured" style={`--proj-accent: ${featuredProject.accent}`}>

      <!-- Left aside: logo + metadata stack -->
      <div class="proj-aside">
        <div class="proj-logo-box">
          <Image
            src={featuredProject.logoSrc}
            alt={featuredProject.logoAlt}
            width={280}
            height={120}
            loading="lazy"
            decoding="async"
            class={`proj-logo ${featuredProject.logoClass ?? "dark:brightness-[2]"}`}
          />
        </div>
        <dl class="proj-meta-stack">
          <div class="proj-meta-item">
            <dt class="proj-meta-label">Programme</dt>
            <dd class="proj-meta-val">{featuredProject.program}</dd>
          </div>
          <div class="proj-meta-item">
            <dt class="proj-meta-label">Duration</dt>
            <dd class="proj-meta-val">{featuredProject.duration}</dd>
          </div>
          <div class="proj-meta-item">
            <dt class="proj-meta-label">AM Role</dt>
            <dd class="proj-meta-val proj-meta-role">{featuredProject.role}</dd>
          </div>
        </dl>
      </div>

      <!-- Right copy -->
      <div class="proj-featured-copy">
        <h3 class="proj-name">{featuredProject.name}</h3>
        <p class="proj-tagline">{featuredProject.tagline}</p>
        <p class="proj-desc">{featuredProject.description}</p>
        <div class="proj-areas" role="list" aria-label="Research areas">
          {featuredProject.areas.map((area) => (
            <span class="proj-area-tag" role="listitem">{area}</span>
          ))}
        </div>
        <a
          class="proj-cta"
          href={featuredProject.href}
          target={featuredProject.external ? "_blank" : undefined}
          rel={featuredProject.external ? "noopener noreferrer" : undefined}
        >
          {featuredProject.external ? "Visit website ↗" : "Read project →"}
        </a>
      </div>

    </article>

    <!-- ── Secondary projects ─────────────────────────── -->
    <div class="proj-grid">
      {
        secondaryProjects.map((project) => (
          <article class="proj-card" style={`--proj-accent: ${project.accent}`}>
            <div class="proj-card-top">
              <div class="proj-card-meta">
                <span class="proj-program">{project.program}</span>
                <span class="proj-duration">{project.duration}</span>
                {project.status && (
                  <span class="proj-status-badge">{project.status}</span>
                )}
              </div>
              <Image
                src={project.logoSrc}
                alt={project.logoAlt}
                width={140}
                height={56}
                loading="lazy"
                decoding="async"
                class={`proj-card-logo dark:brightness-[2] ${project.logoClass ?? ""}`}
              />
            </div>
            <h3 class="proj-name">{project.name}</h3>
            <p class="proj-tagline">{project.tagline}</p>
            <p class="proj-desc proj-desc--clamp">{project.description}</p>
            <div class="proj-areas" role="list" aria-label="Research areas">
              {project.areas.map((area) => (
                <span class="proj-area-tag" role="listitem">{area}</span>
              ))}
            </div>
            <a
              class="proj-cta"
              href={project.href}
              target={project.external ? "_blank" : undefined}
              rel={project.external ? "noopener noreferrer" : undefined}
            >
              {project.external ? "Visit website ↗" : "Read project →"}
            </a>
          </article>
        ))
      }
    </div>

  </div>
</section>

<style>
  /* ── Section header ─────────────────────────────────── */
  .proj-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* ── Featured card ──────────────────────────────────── */
  .proj-featured {
    position: relative;
    border: 1px solid color-mix(in srgb, var(--proj-accent) 24%, var(--border));
    border-radius: 12px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    display: flex;
    transition: border-color 150ms ease, box-shadow 200ms ease;
  }

  /* Left accent bar */
  .proj-featured::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: 12px 0 0 12px;
    background: var(--proj-accent);
    z-index: 1;
  }

  /* Top-left tint */
  .proj-featured::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--proj-accent) 5%, transparent) 0%,
      transparent 48%
    );
    pointer-events: none;
  }

  .proj-featured:hover,
  .proj-featured:focus-within {
    border-color: color-mix(in srgb, var(--proj-accent) 42%, var(--border));
    box-shadow: var(--shadow-strong), inset 0 2px 0 color-mix(in srgb, var(--proj-accent) 50%, transparent);
  }

  /* ── Featured left aside ────────────────────────────── */
  .proj-aside {
    flex-shrink: 0;
    width: 13.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem 1.5rem 1.75rem 2rem;
    position: relative;
    z-index: 1;
  }

  .proj-aside::after {
    content: "";
    position: absolute;
    top: 1rem;
    bottom: 1rem;
    right: 0;
    width: 1px;
    background: var(--border);
  }

  .proj-logo-box {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    min-height: 4rem;
  }

  .proj-logo {
    height: 2.75rem;
    width: auto;
    max-width: 9rem;
    object-fit: contain;
    display: block;
  }

  .proj-meta-stack {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .proj-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .proj-meta-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--muted);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    line-height: 1;
    opacity: 0.7;
  }

  .proj-meta-val {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .proj-meta-role {
    color: color-mix(in srgb, var(--proj-accent) 80%, var(--text));
  }

  /* ── Featured right copy ────────────────────────────── */
  .proj-featured-copy {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.75rem 1.75rem 1.75rem 1.875rem;
    position: relative;
    z-index: 1;
  }

  /* ── Shared type atoms ──────────────────────────────── */
  .proj-program {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--proj-accent) 85%, var(--muted));
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    line-height: 1;
  }

  .proj-duration {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    color: var(--muted);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--surface);
    white-space: nowrap;
    line-height: 1.3;
  }

  .proj-name {
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .proj-tagline {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.45;
    opacity: 0.7;
  }

  .proj-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
    margin-top: 0.05rem;
  }

  .proj-desc--clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Area tags ──────────────────────────────────────── */
  .proj-areas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.25rem;
  }

  .proj-area-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 500;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--muted);
    background: var(--surface);
    letter-spacing: 0.02em;
  }

  /* ── Completed badge ────────────────────────────────── */
  .proj-status-badge {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    color: var(--muted);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--surface);
    white-space: nowrap;
    opacity: 0.8;
  }

  /* ── CTA ────────────────────────────────────────────── */
  .proj-cta {
    display: inline-flex;
    align-items: center;
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.4rem;
    transition: opacity 120ms ease;
  }

  .proj-cta:hover { opacity: 0.72; }

  .proj-cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
    opacity: 1;
  }

  /* ── Secondary grid ─────────────────────────────────── */
  .proj-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  @media (min-width: 640px) {
    .proj-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Secondary cards ────────────────────────────────── */
  .proj-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 1.25rem 1.25rem 1.375rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition: border-color 150ms ease, box-shadow 200ms ease;
  }

  /* Subtle left accent bar */
  .proj-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    border-radius: 12px 0 0 12px;
    background: color-mix(in srgb, var(--proj-accent) 55%, transparent);
  }

  .proj-card:hover,
  .proj-card:focus-within {
    border-color: color-mix(in srgb, var(--proj-accent) 38%, var(--border));
    box-shadow: var(--shadow-strong), inset 0 2px 0 color-mix(in srgb, var(--proj-accent) 50%, transparent);
  }

  .proj-card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.1rem;
  }

  .proj-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 auto;
    flex-wrap: wrap;
  }

  .proj-card-logo {
    height: 2.25rem;
    width: auto;
    max-width: 7rem;
    object-fit: contain;
    opacity: 0.85;
    display: block;
    flex-shrink: 0;
    margin-left: auto;
  }

  /* ── Reduced-motion ──────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .proj-featured,
    .proj-card {
      transition: none;
    }
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 767px) {
    .proj-featured {
      flex-direction: column;
    }

    .proj-aside {
      width: 100%;
      padding: 1.25rem 1.25rem 1rem 1.5rem;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: flex-start;
    }

    .proj-aside::after {
      display: none;
    }

    .proj-logo-box {
      min-height: auto;
      padding: 0.5rem 0.65rem;
      align-self: flex-start;
    }

    .proj-logo {
      height: 2rem;
    }

    .proj-meta-stack {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem 1.5rem;
      flex: 1 1 auto;
    }

    .proj-meta-item {
      gap: 0.15rem;
    }

    .proj-featured-copy {
      padding: 0 1.25rem 1.25rem 1.5rem;
    }
  }

  @media (max-width: 479px) {
    .proj-card-logo {
      display: none;
    }
  }
</style>
