---
import { Image } from "astro:assets";

const featuredProject = {
  name: "CONFIDENTIAL6G",
  tagline: "Quantum-Resistant Security for 6G Networks",
  description:
    "Developing cryptographic protocols and secure architectures for next-generation 6G systems.",
  duration: "2023–2025",
  program: "EU Horizon Europe",
  href: "/projects/confidential6g/",
  logoSrc: "/img/logos/confidential6G.jpg",
  logoAlt: "CONFIDENTIAL6G logo",
  external: false,
  accent: "#4c83ff",
};

const secondaryProjects = [
  {
    name: "Elastic",
    tagline: "Next-Gen Network Orchestration",
    description:
      "WebAssembly-based orchestration with confidential computing for cloud-edge workloads.",
    duration: "2023–2027",
    program: "EU Horizon Europe",
    href: "/projects/elastic/",
    logoSrc: "/img/logos/elastic.png",
    logoAlt: "Elastic project logo",
    logoClass: "invert dark:invert-0",
    external: false,
    accent: "#34c38f",
  },
  {
    name: "EdgeX Foundry",
    tagline: "Open Source Edge Platform",
    description:
      "Open ecosystem contribution for interoperable edge deployments and cloud-edge connectivity.",
    duration: "2017–Present",
    program: "Linux Foundation",
    href: "https://www.edgexfoundry.org",
    logoSrc: "/img/logos/lf.png",
    logoAlt: "Linux Foundation logo",
    external: true,
    accent: "#8090b8",
  },
];
---

<section
  id="projects-preview"
  class="scroll-mt-16"
  style="padding-top: clamp(2.5rem, 4vw, 4rem); padding-bottom: clamp(2.5rem, 4vw, 4rem);"
>
  <div class="container-wide">

    <div class="proj-head">
      <div>
        <p class="section-label">Research &amp; Collaborations</p>
        <h2 class="section-title mt-0.5">Projects</h2>
      </div>
      <a class="button-secondary proj-view-all" href="/projects/">View all →</a>
    </div>

    <!-- Featured project -->
    <article class="proj-featured" style={`--proj-accent: ${featuredProject.accent}`}>
      <div class="proj-featured-inner">
        <div class="proj-featured-copy">
          <div class="proj-meta-row">
            <span class="proj-program">{featuredProject.program}</span>
            <span class="proj-duration">{featuredProject.duration}</span>
          </div>
          <h3 class="proj-name">{featuredProject.name}</h3>
          <p class="proj-tagline">{featuredProject.tagline}</p>
          <p class="proj-desc">{featuredProject.description}</p>
          <a
            class="proj-cta"
            href={featuredProject.href}
            target={featuredProject.external ? "_blank" : undefined}
            rel={featuredProject.external ? "noopener noreferrer" : undefined}
          >
            {featuredProject.external ? "Visit website ↗" : "Read project →"}
          </a>
        </div>
        <div class="proj-logo-aside">
          <Image
            src={featuredProject.logoSrc}
            alt={featuredProject.logoAlt}
            width={280}
            height={120}
            loading="lazy"
            decoding="async"
            class="proj-logo dark:brightness-[2]"
          />
        </div>
      </div>
    </article>

    <!-- Secondary projects -->
    <div class="proj-grid">
      {
        secondaryProjects.map((project) => (
          <article class="proj-card" style={`--proj-accent: ${project.accent}`}>
            <div class="proj-meta-row">
              <span class="proj-program">{project.program}</span>
              <span class="proj-duration">{project.duration}</span>
              <Image
                src={project.logoSrc}
                alt={project.logoAlt}
                width={72}
                height={36}
                loading="lazy"
                decoding="async"
                class={`proj-card-logo dark:brightness-[2] ${project.logoClass ?? ""}`}
              />
            </div>
            <h3 class="proj-name">{project.name}</h3>
            <p class="proj-tagline">{project.tagline}</p>
            <p class="proj-desc proj-desc--clamp">{project.description}</p>
            <a
              class="proj-cta"
              href={project.href}
              target={project.external ? "_blank" : undefined}
              rel={project.external ? "noopener noreferrer" : undefined}
            >
              {project.external ? "Visit website ↗" : "Read project →"}
            </a>
          </article>
        ))
      }
    </div>

  </div>
</section>

<style>
  /* ── Section header ─────────────────────────────────── */
  .proj-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* ── Featured card ──────────────────────────────────── */
  .proj-featured {
    position: relative;
    border: 1px solid color-mix(in srgb, var(--proj-accent) 24%, var(--border));
    border-radius: 12px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition: border-color 150ms ease, box-shadow 200ms ease;
  }

  /* Left accent bar */
  .proj-featured::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    border-radius: 12px 0 0 12px;
    background: var(--proj-accent);
  }

  /* Top-left tint overlay */
  .proj-featured::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--proj-accent) 5%, transparent) 0%,
      transparent 48%
    );
    pointer-events: none;
  }

  .proj-featured:hover,
  .proj-featured:focus-within {
    border-color: color-mix(in srgb, var(--proj-accent) 42%, var(--border));
    box-shadow: var(--shadow-strong), inset 0 2px 0 color-mix(in srgb, var(--proj-accent) 55%, transparent);
  }

  .proj-featured-inner {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 1.5rem 1.5rem 1.5rem 1.75rem;
  }

  .proj-featured-copy {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .proj-logo-aside {
    flex-shrink: 0;
    align-self: flex-start;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .proj-logo {
    height: 3.25rem;
    width: auto;
    max-width: 9rem;
    object-fit: contain;
    display: block;
  }

  /* ── Shared type atoms ──────────────────────────────── */
  .proj-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .proj-program {
    font-size: 0.67rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--proj-accent) 85%, var(--muted));
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    line-height: 1;
  }

  .proj-duration {
    font-size: 0.67rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    color: var(--muted);
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--surface);
    white-space: nowrap;
    line-height: 1.3;
  }

  .proj-card-logo {
    height: 1.35rem;
    width: auto;
    max-width: 4rem;
    object-fit: contain;
    opacity: 0.7;
    display: block;
    margin-left: auto;
  }

  .proj-name {
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-top: 0.1rem;
  }

  .proj-tagline {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.45;
    opacity: 0.72;
  }

  .proj-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    margin-top: 0.05rem;
  }

  .proj-desc--clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .proj-cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.35rem;
    transition: opacity 120ms ease;
  }

  .proj-cta:hover { opacity: 0.72; }

  .proj-cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
    opacity: 1;
  }

  /* ── Secondary grid ─────────────────────────────────── */
  .proj-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  @media (min-width: 640px) {
    .proj-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Secondary cards ────────────────────────────────── */
  .proj-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 1.25rem 1.25rem 1.375rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--panel);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    transition: border-color 150ms ease, box-shadow 200ms ease;
  }

  /* Subtle left accent bar */
  .proj-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    border-radius: 12px 0 0 12px;
    background: color-mix(in srgb, var(--proj-accent) 55%, transparent);
  }

  .proj-card:hover,
  .proj-card:focus-within {
    border-color: color-mix(in srgb, var(--proj-accent) 38%, var(--border));
    box-shadow: var(--shadow-strong), inset 0 2px 0 color-mix(in srgb, var(--proj-accent) 50%, transparent);
  }

  /* ── Reduced-motion override ─────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .proj-featured,
    .proj-card {
      transition: none;
    }
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 639px) {
    .proj-logo-aside {
      display: none;
    }

    .proj-featured-inner {
      padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    }
  }
</style>
