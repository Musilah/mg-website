---
const {
  title,
  subtitle,
  primary,
  secondary,
  kicker,
  backgroundClass = "",
} = Astro.props;
---

<section class={`page-hero ${backgroundClass}`}>
  <div class="container-wide">
    <div class="page-hero-inner">
      {kicker
        ? <p class="page-hero-kicker">{kicker}</p>
        : <p class="page-hero-kicker" aria-hidden="true">Abstract Machines</p>
      }
      <h1 class="page-hero-title">{title}</h1>
      {subtitle && <p class="page-hero-subtitle">{subtitle}</p>}
      {(primary || secondary) && (
        <div class="page-hero-ctas">
          {primary && (
            <a
              class="button-primary"
              href={primary.href}
              target={primary.external ? "_blank" : undefined}
              rel={primary.external ? "noopener noreferrer" : undefined}
            >
              {primary.label}
            </a>
          )}
          {secondary && (
            <a
              class="button-secondary"
              href={secondary.href}
              target={secondary.external ? "_blank" : undefined}
              rel={secondary.external ? "noopener noreferrer" : undefined}
            >
              {secondary.label}
            </a>
          )}
        </div>
      )}
    </div>
    <slot />
  </div>
</section>

<style>
  .page-hero {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: clamp(2.5rem, 4vw, 4rem);
    text-align: center;
  }

  .page-hero-inner {
    max-width: 52rem;
    margin-inline: auto;
  }

  .page-hero-kicker {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0.9;
  }

  .page-hero-title {
    font-size: clamp(2.7rem, 6vw, 4.75rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.02;
    color: var(--text);
    margin-top: 0.75rem;
  }

  .page-hero-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    color: var(--muted);
    line-height: 1.72;
    margin-top: 1rem;
    max-width: 54ch;
    margin-inline: auto;
  }

  .page-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
    justify-content: center;
  }
</style>
